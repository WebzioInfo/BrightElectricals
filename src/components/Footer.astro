---
// ============================================================
// Footer.astro — Premium multi-column footer
// ============================================================
import { company } from '@data/company';
import { services } from '@data/services';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Home',            href: '/'          },
  { label: 'Services',        href: '/services/' },
  { label: 'About Us',        href: '/about/'    },
  { label: 'Contact',         href: '/contact/'  },
  { label: 'Privacy Policy',  href: '/privacy-policy/' },
];
---

<footer class="bg-brand-dark text-white" role="contentinfo">
  <!-- Top wave divider -->
  <div class="h-px bg-gradient-to-r from-transparent via-brand-accent/30 to-transparent" />

  <!-- Main Footer Content -->
  <div class="container py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Col 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5 group w-fit" aria-label="Bright Electrical homepage">
          <img
            src="/images/logo.png"
            alt="Bright Electrical logo"
            width="44"
            height="44"
            class="w-11 h-11 object-contain brightness-200 transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
          <div>
            <p class="font-display font-700 text-white text-lg leading-none">Bright Electrical</p>
            <p class="text-2xs text-white/50 mt-0.5">&amp; Engineering Works</p>
          </div>
        </a>
        <p class="text-sm text-white/65 leading-relaxed mb-6 max-w-xs">
          Kerala's trusted electrical engineering partner. Licensed, certified, and committed to quality across residential, commercial, and industrial projects.
        </p>

        <!-- Contact quick access -->
        <div class="space-y-3">
          <a
            href={`tel:${company.phone}`}
            class="flex items-center gap-3 text-sm text-white/70 hover:text-brand-accent-light transition-colors duration-200 group"
            aria-label={`Call ${company.phoneDisplay}`}
          >
            <span class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-accent/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.1a16 16 0 006 6l1.41-1.41a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15z"/>
              </svg>
            </span>
            {company.phoneDisplay}
          </a>
          <a
            href={company.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-sm text-white/70 hover:text-brand-accent-light transition-colors duration-200 group"
            aria-label="Chat on WhatsApp"
          >
            <span class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0 group-hover:bg-[#25D366]/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            Chat on WhatsApp
          </a>
          <div class="flex items-start gap-3 text-sm text-white/70">
            <span class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </span>
            <span>{company.address.full}</span>
          </div>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="font-display font-600 text-white text-sm mb-5 uppercase tracking-widest">Quick Links</h3>
        <ul class="space-y-2.5" role="list">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/60 hover:text-brand-accent-light transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-1 h-1 rounded-full bg-brand-accent/40 group-hover:bg-brand-accent transition-colors" aria-hidden="true" />
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h3 class="font-display font-600 text-white text-sm mb-5 uppercase tracking-widest">Services</h3>
        <ul class="space-y-2.5" role="list">
          {services.map(service => (
            <li>
              <a
                href={`/services/#${service.id}`}
                class="text-sm text-white/60 hover:text-brand-accent-light transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-1 h-1 rounded-full bg-brand-accent/40 group-hover:bg-brand-accent transition-colors" aria-hidden="true" />
                {service.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Business Hours -->
      <div>
        <h3 class="font-display font-600 text-white text-sm mb-5 uppercase tracking-widest">Business Hours</h3>
        <div class="space-y-3 text-sm text-white/60">
          <div>
            <p class="font-medium text-white/80">Monday – Saturday</p>
            <p>8:00 AM – 7:00 PM</p>
          </div>
          <div>
            <p class="font-medium text-white/80">Sunday</p>
            <p>9:00 AM – 5:00 PM</p>
          </div>
          <div class="pt-2 border-t border-white/10">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75" />
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500" />
              </span>
              <p class="font-medium text-green-400">24/7 Emergency Available</p>
            </div>
          </div>
          <p class="text-white/50 text-xs">Serving all of Kerala</p>
        </div>

        <!-- CTA -->
        <a
          href="/contact/"
          class="mt-6 btn btn-sm btn-accent w-full justify-center"
        >
          Get Free Quote
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/40 text-center sm:text-left">
        &copy; {currentYear} {company.name}. All rights reserved.
      </p>
      <p class="text-xs text-white/40 text-center sm:text-right">
        Designed &amp; developed by{' '}
        <a
          href={company.poweredBy.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-accent-light/70 hover:text-brand-accent-light transition-colors font-medium"
        >
          {company.poweredBy.name}
        </a>
      </p>
    </div>
  </div>
</footer>

---
// ============================================================
// BaseLayout.astro — HTML shell for every page
// Handles: SEO, JSON-LD, Open Graph, fonts, preloads, View Transitions
// ============================================================
import '../styles/global.css';
import { company } from '@data/company';
import { defaultSEO, type SEOConfig } from '@data/seo';
import { buildLocalBusinessSchema, buildWebSiteSchema } from '@lib/schema';
import { ViewTransitions } from 'astro:transitions';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import FloatingCTA from '@components/FloatingCTA.astro';
import BackToTop from '@components/BackToTop.astro';

export interface Props {
  seo?:        Partial<SEOConfig>;
  jsonLd?:     object[];
  class?:      string;
}

const {
  seo    = {},
  jsonLd = [],
  class: className,
} = Astro.props;

const meta = { ...defaultSEO, ...seo };
const title       = meta.title ?? defaultSEO.title;
const description = meta.description ?? defaultSEO.description;
const canonical   = meta.canonical ?? Astro.url.href;
const ogImage     = meta.ogImage ?? defaultSEO.ogImage;
const noIndex     = meta.noIndex ?? false;

const isHomePage = Astro.url.pathname === '/';

const allSchemas = [
  ...(isHomePage ? [buildLocalBusinessSchema(), buildWebSiteSchema()] : []),
  ...jsonLd,
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Electrical Contractor Kerala, Domestic Wiring, Industrial Panels, CCTV Installation, Smart Home Automation, Electrical Maintenance, Nilambur Electrician, Bright Electrical, Electrical Services Kerala, Malappuram Electrician" />
  <meta name="author" content={company.name} />
  {noIndex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="business.business" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={company.name} />
  <meta property="og:image" content={`${company.site.url}${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${company.shortName} — Electrical Contractor Kerala`} />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${company.site.url}${ogImage}`} />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0C1A2A" />
  <meta name="msapplication-TileColor" content="#0C1A2A" />

  <!-- DNS Prefetch / Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

  <!-- Font preload -->
  <link
    rel="preload"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </noscript>

  <!-- Astro View Transitions -->
  <ViewTransitions />

  <!-- JSON-LD -->
  {allSchemas.length > 0 && allSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <slot name="head" />
</head>

<body class:list={['antialiased', className]} style="background: var(--warm-white); color: var(--text-primary);">

  <!-- Skip link -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand-primary focus:text-white focus:rounded-lg focus:shadow-lg focus:text-sm focus:font-medium"
  >
    Skip to main content
  </a>

  <Navbar transition:persist />

  <main id="main-content" tabindex="-1" transition:animate="fade">
    <slot />
  </main>

  <Footer />
  <FloatingCTA />
  <BackToTop />

  <!-- Global IntersectionObserver for reveal animations -->
  <script>
    function initReveals() {
      const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
      if (els.length === 0) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      els.forEach((el) => observer.observe(el));
    }

    // Run on initial load and after view transitions
    initReveals();
    document.addEventListener('astro:page-load', initReveals);
  </script>

  <!-- Lenis Smooth Scroll Integration -->
  <script>
    import Lenis from 'lenis';

    let lenisInstance: Lenis | null = null;
    let rafId: number | null = null;

    function initLenis() {
      // 1. Respect prefers-reduced-motion
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        destroyLenis();
        return;
      }

      // 2. Breakpoint check: ONLY initialize on Desktop (width >= 1024px)
      const isDesktop = window.innerWidth >= 1024;
      if (!isDesktop) {
        destroyLenis();
        return;
      }

      // 3. Prevent duplicate initialization
      if (lenisInstance) return;

      // 4. Initialize Lenis
      lenisInstance = new Lenis({
        duration: 0.9,      // Premium smooth duration
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        syncTouch: true,    // Smoothed trackpad/gestures on desktop
      });

      // 5. requestAnimationFrame loop
      function raf(time: number) {
        lenisInstance?.raf(time);
        rafId = requestAnimationFrame(raf);
      }
      rafId = requestAnimationFrame(raf);

      // 6. Connect Lenis scrolling to GSAP ScrollTrigger updates
      lenisInstance.on('scroll', () => {
        const ScrollTrigger = (window as any).ScrollTrigger;
        if (ScrollTrigger) {
          ScrollTrigger.update();
        }
      });
    }

    function destroyLenis() {
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
      if (lenisInstance) {
        lenisInstance.destroy();
        lenisInstance = null;
      }
    }

    // Handle window resize dynamically to enable/disable Lenis at the 1024px boundary
    let resizeTimeout: any = null;
    function handleResize() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const isDesktop = window.innerWidth >= 1024;
        if (isDesktop) {
          if (!lenisInstance) {
            initLenis();
          }
        } else {
          if (lenisInstance) {
            destroyLenis();
          }
        }
      }, 150); // debounce window resize events
    }

    // Bind initialization and cleanup hooks
    function setup() {
      initLenis();
      window.removeEventListener('resize', handleResize);
      window.addEventListener('resize', handleResize);
    }

    function cleanup() {
      destroyLenis();
      window.removeEventListener('resize', handleResize);
    }

    setup();
    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-swap', cleanup);
  </script>
</body>
</html>

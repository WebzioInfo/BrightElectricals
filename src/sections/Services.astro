---
// ============================================================
// Services.astro — Pinned Split-Screen Scroll Storytelling
// GSAP ScrollTrigger driven • Cinematic image reveals
// Left: pinned info panel that morphs per service
// Right: stacked images that reveal via clip-path on scroll
// Mobile: vertical card storytelling
// ============================================================
import { services } from '@data/services';

// Curated copy for each service — more editorial than the data file
const editorial = [
  {
    headline: 'Home Electrical\nSolutions',
    tagline: 'Where safety meets comfort.',
    copy: 'Complete residential electrical systems engineered for modern living. From precision wiring to intelligent lighting — every circuit designed to last decades.',
    features: ['Full-home wiring & rewiring', 'Distribution board installation', 'Earth leakage protection', 'LED lighting systems'],
  },
  {
    headline: 'Industrial Power\nSystems',
    tagline: 'Engineered for uptime.',
    copy: 'High-capacity power distribution for manufacturing, warehousing, and heavy industry. Built to Kerala Electricity Board standards with zero compromise on safety.',
    features: ['Heavy-duty power distribution', 'Machine wiring & commissioning', 'MCC & PCC panels', 'Annual maintenance contracts'],
  },
  {
    headline: 'ATS & AMF\nPanel Setup',
    tagline: 'Power that never stops.',
    copy: 'Automatic Transfer Switch and Mains Failure panels ensuring instantaneous switchover. Your operations stay protected — even when the grid doesn\'t.',
    features: ['Automatic Transfer Switches', 'AMF panel commissioning', 'Generator synchronization', 'Remote monitoring integration'],
  },
  {
    headline: 'Automation &\nSmart Control',
    tagline: 'Intelligence, built in.',
    copy: 'From smart lighting to PLC-based industrial automation — intelligent systems that reduce energy consumption while maximizing control and comfort.',
    features: ['Smart home systems', 'Industrial PLC automation', 'IoT sensor integration', 'Energy monitoring dashboards'],
  },
  {
    headline: 'Structured Cabling\n& Networks',
    tagline: 'Infrastructure that scales.',
    copy: 'Enterprise-grade structured cabling following TIA/EIA standards. Server room builds, campus networks, and fiber optic deployments — built for tomorrow\'s bandwidth.',
    features: ['Cat6/Cat6A cabling', 'Fiber optic installation', 'Server room builds', 'Testing & Fluke certification'],
  },
  {
    headline: 'Surveillance &\nSecurity Systems',
    tagline: 'Total visibility. Total control.',
    copy: 'Comprehensive security ecosystems combining HD/4K CCTV, biometric access, and integrated alarms — with 24/7 remote monitoring from your smartphone.',
    features: ['HD/4K IP camera systems', 'NVR/DVR recording', 'Biometric access control', 'Smart alarm integration'],
  },
  {
    headline: 'Repair &\nMaintenance',
    tagline: 'We never rest.',
    copy: 'Emergency response. Fault diagnosis. Preventive maintenance. Our rapid-response team is available around the clock — because electrical problems never wait.',
    features: ['24/7 emergency response', 'Fault detection & diagnosis', 'Preventive maintenance', 'Safety audits & compliance'],
  },
];
---

<!-- ═══════════════════════════════════════════════════════════════
     SERVICES — SCROLL-DRIVEN STORYTELLING
     ═══════════════════════════════════════════════════════════════ -->

<!-- Desktop: Pinned split-screen -->
<section
  id="services"
  class="svc-section relative"
  aria-labelledby="svc-heading"
>
  <!-- Screen-reader-only heading -->
  <h2 id="svc-heading" class="sr-only">Our Services</h2>

  <!-- ── DESKTOP EXPERIENCE (hidden on mobile) ──────────────── -->
  <div class="svc-desktop hidden lg:block">

    <!-- This wrapper is tall — GSAP pins .svc-pin inside it -->
    <div class="svc-scroll-wrapper relative" style={`height: ${services.length * 100}vh;`}>

      <!-- Pinned viewport -->
      <div class="svc-pin w-full h-screen flex overflow-hidden" style="background: var(--deep-navy);">

        <!-- LEFT PANEL — info that morphs -->
        <div class="svc-left relative flex flex-col justify-center" style="width: 42%; padding: clamp(3rem,5vw,6rem);">

          <!-- Background texture -->
          <div class="absolute inset-0 texture-blueprint" aria-hidden="true"></div>

          <!-- Section label -->
          <div class="relative z-10">
            <p class="section-label section-label-light mb-8">Our Capabilities</p>
          </div>

          <!-- Service info container — all 7 stacked, only one visible -->
          <div class="svc-info-stack relative z-10" style="min-height: 340px;">
            {editorial.map((svc, i) => (
              <div
                class:list={['svc-info absolute inset-0 flex flex-col justify-center', i === 0 ? 'active' : '']}
                data-svc-index={i}
              >
                <!-- Number -->
                <span
                  class="svc-num block font-display font-800 mb-4"
                  style="font-size: clamp(0.75rem, 1vw, 0.875rem); letter-spacing: 0.15em; color: var(--brand-accent-lt);"
                  aria-hidden="true"
                >
                  {String(i + 1).padStart(2, '0')} / {String(services.length).padStart(2, '0')}
                </span>

                <!-- Headline -->
                <h3
                  class="svc-title font-display font-800 text-white mb-4"
                  style="font-size: clamp(2rem, 3.5vw, 3.25rem); letter-spacing: -0.04em; line-height: 1.05; white-space: pre-line;"
                >
                  {svc.headline}
                </h3>

                <!-- Tagline -->
                <p class="svc-tagline mb-5" style="font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); font-weight: 500; color: var(--brand-accent-lt); letter-spacing: -0.01em;">
                  {svc.tagline}
                </p>

                <!-- Copy -->
                <p class="svc-copy mb-6" style="font-size: clamp(0.8125rem, 1vw, 0.9375rem); line-height: 1.8; color: #94A3B8; max-width: 420px;">
                  {svc.copy}
                </p>

                <!-- Features (mini list) -->
                <ul class="svc-features flex flex-wrap gap-x-4 gap-y-2 mb-8" role="list">
                  {svc.features.map(f => (
                    <li class="flex items-center gap-1.5" style="font-size: 0.75rem; font-weight: 600; color: #64748B;">
                      <span class="w-1 h-1 rounded-full bg-brand-accent flex-shrink-0" aria-hidden="true"></span>
                      {f}
                    </li>
                  ))}
                </ul>

                <!-- CTA -->
                <div class="svc-cta">
                  <a
                    href={`/contact/?service=${encodeURIComponent(services[i].title)}`}
                    class="btn btn-pill btn-accent"
                    style="font-size: 0.8125rem;"
                  >
                    Request Quote
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>

          <!-- Progress dots -->
          <div class="svc-dots relative z-10 flex items-center gap-2 mt-8" aria-hidden="true">
            {services.map((_, i) => (
              <button
                class:list={['svc-dot', i === 0 ? 'active' : '']}
                data-dot={i}
                aria-label={`Go to service ${i + 1}`}
              />
            ))}
          </div>
        </div>

        <!-- RIGHT PANEL — cinematic images -->
        <div class="svc-right relative" style="width: 58%; overflow: hidden;">

          <!-- Image stack -->
          {services.map((svc, i) => (
            <div
              class:list={['svc-img-wrap absolute inset-0', i === 0 ? 'active' : '']}
              data-img-index={i}
            >
              <img
                src={svc.image}
                alt={svc.title}
                width="1200"
                height="800"
                class="svc-img w-full h-full object-cover"
                loading={i < 2 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <!-- Dark gradient overlay -->
              <div class="absolute inset-0" style="background: linear-gradient(90deg, var(--deep-navy) 0%, rgba(12,26,42,0.25) 30%, rgba(12,26,42,0.05) 60%, rgba(12,26,42,0.2) 100%);" aria-hidden="true"></div>
              <!-- Bottom/top vignette -->
              <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(12,26,42,0.3) 0%, transparent 20%, transparent 80%, rgba(12,26,42,0.4) 100%);" aria-hidden="true"></div>
            </div>
          ))}

          <!-- Large ghosted number overlay -->
          <div class="svc-ghost-num absolute z-10 pointer-events-none" style="bottom: clamp(2rem,4vw,4rem); right: clamp(2rem,4vw,4rem);">
            <span class="font-display font-900" style="font-size: clamp(8rem, 15vw, 14rem); line-height: 0.85; letter-spacing: -0.06em; color: rgba(255,255,255,0.04);">
              <span class="svc-ghost-text">01</span>
            </span>
          </div>

        </div>

      </div>
    </div>
  </div>

  <!-- ── MOBILE EXPERIENCE ──────────────────────────────────── -->
  <div class="svc-mobile lg:hidden" style="background: var(--deep-navy);">

    <!-- Header -->
    <div class="container" style="padding-top: clamp(3rem,8vw,5rem); padding-bottom: clamp(2rem,4vw,3rem);">
      <p class="section-label section-label-light mb-4 reveal">Our Capabilities</p>
      <h2 class="heading-lg text-white mb-4 reveal delay-100" style="max-width: 320px;">
        Complete Electrical Solutions
      </h2>
    </div>

    <!-- Mobile cards — vertical storytelling -->
    <div class="svc-mobile-cards">
      {services.map((svc, i) => {
        const ed = editorial[i];
        return (
          <article
            class="svc-mobile-card relative overflow-hidden reveal"
            style={`transition-delay: ${Math.min(i * 60, 300)}ms`}
          >
            <!-- Image -->
            <div class="relative" style="aspect-ratio: 16/10; overflow: hidden;">
              <img
                src={svc.image}
                alt={svc.title}
                width="800"
                height="500"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 30%, rgba(12,26,42,0.9) 100%);" aria-hidden="true"></div>

              <!-- Number overlay -->
              <span
                class="absolute top-4 left-4 font-display font-800"
                style="font-size: 0.6875rem; letter-spacing: 0.12em; color: var(--brand-accent-lt);"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>

              <!-- Title on image -->
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <h3 class="font-display font-800 text-white mb-1" style="font-size: clamp(1.25rem, 5vw, 1.5rem); letter-spacing: -0.03em; line-height: 1.1;">
                  {svc.shortTitle}
                </h3>
                <p style="font-size: 0.8125rem; font-weight: 500; color: var(--brand-accent-lt);">
                  {ed.tagline}
                </p>
              </div>
            </div>

            <!-- Content -->
            <div style="padding: 1.25rem 1.25rem 1.5rem; background: var(--steel-gray);">
              <p style="font-size: 0.8125rem; line-height: 1.7; color: #94A3B8; margin-bottom: 1rem;">
                {ed.copy}
              </p>
              <a
                href={`/contact/?service=${encodeURIComponent(svc.title)}`}
                class="inline-flex items-center gap-1.5 text-xs font-semibold"
                style="color: var(--brand-accent-lt); letter-spacing: 0.02em;"
              >
                Request Quote
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <!-- View all link -->
    <div class="container flex justify-center" style="padding-block: clamp(2rem,5vw,3rem);">
      <a href="/services/" class="btn btn-pill btn-outline-light" style="font-size: 0.8125rem;">
        View All Services
      </a>
    </div>
  </div>

</section>

<!-- ═══════════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════════ -->
<style>
  /* ── Desktop pinned section ──────────────────────── */
  .svc-section {
    position: relative;
    z-index: 1;
  }

  /* Info slides */
  .svc-info {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s cubic-bezier(0.22,1,0.36,1), transform 0.5s cubic-bezier(0.22,1,0.36,1);
    pointer-events: none;
  }
  .svc-info.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Image slides */
  .svc-img-wrap {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 0.7s cubic-bezier(0.22,1,0.36,1);
    z-index: 1;
  }
  .svc-img-wrap.active {
    clip-path: inset(0 0 0 0);
    z-index: 2;
  }

  .svc-img {
    transform: scale(1.08);
    transition: transform 4s cubic-bezier(0.22,1,0.36,1);
  }
  .svc-img-wrap.active .svc-img {
    transform: scale(1.0);
  }

  /* Progress dots */
  .svc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(148,163,184,0.2);
    border: none;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.22,1,0.36,1);
    padding: 0;
  }
  .svc-dot.active {
    width: 28px;
    border-radius: 99px;
    background: var(--brand-accent);
  }
  .svc-dot:hover:not(.active) {
    background: rgba(148,163,184,0.4);
  }

  /* ── Mobile cards ────────────────────────────────── */
  .svc-mobile-cards {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1rem);
    padding-inline: clamp(1rem, 4vw, 1.5rem);
  }

  .svc-mobile-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(148,163,184,0.08);
  }

  /* ── Reduced motion ──────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .svc-info { transition: none; opacity: 1; transform: none; }
    .svc-img-wrap { clip-path: inset(0) !important; transition: none; }
    .svc-img { transform: none !important; transition: none; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════════
     GSAP ScrollTrigger — Desktop scroll-driven transitions
     ═══════════════════════════════════════════════════════════════ -->
<script>
  // Dynamically load GSAP + ScrollTrigger without race conditions
  function loadScript(src: string, globalVar: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if ((window as any)[globalVar]) { resolve(); return; }
      
      const existing = document.querySelector(`script[src="${src}"]`) as HTMLScriptElement | null;
      if (existing) {
        if ((window as any)[globalVar]) {
          resolve();
        } else {
          existing.addEventListener('load', () => resolve());
          existing.addEventListener('error', reject);
        }
        return;
      }
      
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function initServicesScroll() {
    // Only run on desktop
    if (window.innerWidth < 1024) return;

    const wrapper = document.querySelector('.svc-scroll-wrapper') as HTMLElement | null;
    const pin     = document.querySelector('.svc-pin') as HTMLElement | null;
    if (!wrapper || !pin) return;

    // Load GSAP and ScrollTrigger robustly
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js', 'gsap');
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js', 'ScrollTrigger');

    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    gsap.registerPlugin(ScrollTrigger);

    // Clean up existing ScrollTrigger on this ID to avoid duplicate bindings during View Transitions
    const existingTrigger = ScrollTrigger.getById('services-trigger');
    if (existingTrigger) {
      existingTrigger.kill();
    }

    const infos    = pin.querySelectorAll<HTMLElement>('.svc-info');
    const images   = pin.querySelectorAll<HTMLElement>('.svc-img-wrap');
    const dots     = pin.querySelectorAll<HTMLElement>('.svc-dot');
    const ghostTxt = pin.querySelector('.svc-ghost-text') as HTMLElement | null;
    const total    = infos.length;
    let currentIdx = 0;

    function goTo(index: number) {
      if (index === currentIdx && infos[index]?.classList.contains('active')) return;
      currentIdx = index;

      // Animate info panels
      infos.forEach((el, i) => {
        el.classList.toggle('active', i === index);
      });

      // Animate images deterministically to support smooth forward & backward scrubs
      images.forEach((el, i) => {
        if (i === index) {
          el.classList.add('active');
          el.style.clipPath = 'inset(0 0 0 0)';
          el.style.zIndex = '2';
        } else if (i < index) {
          el.classList.remove('active');
          el.style.clipPath = 'inset(0 0 100% 0)';
          el.style.zIndex = '1';
        } else {
          el.classList.remove('active');
          el.style.clipPath = 'inset(100% 0 0 0)';
          el.style.zIndex = '1';
        }
      });

      // Update dots
      dots.forEach((d, i) => d.classList.toggle('active', i === index));

      // Update ghost number
      if (ghostTxt) ghostTxt.textContent = String(index + 1).padStart(2, '0');
    }

    // Pin the section and scrub through services (pinSpacing: true ensures page length is correctly calculated)
    ScrollTrigger.create({
      id: 'services-trigger',
      trigger: wrapper,
      start: 'top top',
      end: 'bottom bottom',
      pin: pin,
      pinSpacing: true,
      onUpdate: (self: any) => {
        const progress = self.progress; // 0 → 1
        const idx = Math.min(Math.floor(progress * total), total - 1);
        goTo(idx);
      },
    });

    // Dot clicks
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const wrapperRect = wrapper.getBoundingClientRect();
        const wrapperTop = window.scrollY + wrapperRect.top;
        const scrollTarget = wrapperTop + (i / total) * wrapper.offsetHeight + 10;
        window.scrollTo({ top: scrollTarget, behavior: 'smooth' });
      });
    });

    // Initialize first slide
    goTo(0);
  }

  // Run on load and page transition
  initServicesScroll();
  document.addEventListener('astro:page-load', initServicesScroll);
</script>

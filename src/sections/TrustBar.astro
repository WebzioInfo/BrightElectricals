---
// TrustBar.astro — Trust indicators strip below hero

const trustItems = [
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'Licensed & Certified' },
  { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '24/7 Emergency Service' },
  { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Pan-Kerala Coverage' },
  { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', label: '500+ Projects Delivered' },
  { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', label: 'Free Site Estimates' },
  { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Safety Code Compliant' },
];
---

<section class="relative bg-white border-y border-surface-100 py-6 lg:py-8 overflow-hidden" aria-label="Trust indicators">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-accent/20 to-transparent" aria-hidden="true" />

  <div class="container">
    <ul
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 lg:gap-2"
      role="list"
      aria-label="Our guarantees"
    >
      {trustItems.map((item, i) => (
        <li
          class="flex flex-col sm:flex-row items-center sm:items-center gap-2 sm:gap-2.5 text-center sm:text-left reveal"
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="w-8 h-8 rounded-lg bg-brand-primary/6 flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-brand-primary"
            >
              <path d={item.icon} />
            </svg>
          </div>
          <span class="text-xs sm:text-2xs font-semibold text-surface-600 leading-tight">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

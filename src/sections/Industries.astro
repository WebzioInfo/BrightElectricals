---
// Industries.astro — Industries served section

const industries = [
  {
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    name: 'Residential',
    desc: 'Homes, apartments, villas, and housing societies',
    image: '/images/industries/residential.jpg',
  },
  {
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    name: 'Commercial',
    desc: 'Offices, retail spaces, malls, and showrooms',
    image: '/images/industries/commercial.jpg',
  },
  {
    icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
    name: 'Industrial',
    desc: 'Factories, manufacturing units, and warehouses',
    image: '/images/industries/industrial.jpg',
  },
  {
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    name: 'Healthcare',
    desc: 'Hospitals, clinics, and diagnostic centers',
    image: '/images/industries/healthcare.jpg',
  },
  {
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
    name: 'Education',
    desc: 'Schools, colleges, and training centers',
    image: '/images/industries/education.jpg',
  },
  {
    icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    name: 'Hospitality',
    desc: 'Hotels, resorts, and restaurants',
    image: '/images/industries/hospitality.jpg',
  },
];
---

<section
  class="section bg-surface-50"
  aria-labelledby="industries-heading"
>
  <div class="container">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-14">
      <p class="section-label mb-3 reveal">Industries We Serve</p>
      <h2
        id="industries-heading"
        class="font-display font-800 text-surface-900 mb-4 reveal"
        style="font-size: clamp(1.875rem, 3.5vw, 2.75rem); letter-spacing: -0.025em; line-height: 1.12; transition-delay: 100ms;"
      >
        Powering Every Sector
      </h2>
      <p class="text-surface-500 leading-relaxed reveal" style="transition-delay: 200ms;">
        Our expertise spans across all major industry verticals in Kerala.
      </p>
    </div>

    <!-- Industries grid -->
    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4"
      role="list"
      aria-label="Industries we serve"
    >
      {industries.map((industry, i) => (
        <div
          class="group relative rounded-2xl overflow-hidden cursor-default reveal"
          style={`transition-delay: ${i * 90}ms`}
          role="listitem"
        >
          <!-- Background image -->
          <div class="aspect-[3/4] relative">
            <img
              src={industry.image}
              alt={`Electrical services for ${industry.name} sector`}
              width="200"
              height="266"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/40 to-brand-dark/10 transition-opacity duration-300 group-hover:from-brand-dark/95" aria-hidden="true" />

            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-4">
              <div class="w-8 h-8 rounded-lg bg-brand-accent/80 flex items-center justify-center mb-2 transition-transform duration-300 group-hover:scale-110" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={industry.icon} />
                </svg>
              </div>
              <h3 class="font-display font-700 text-white text-sm leading-tight mb-1">
                {industry.name}
              </h3>
              <p class="text-2xs text-white/65 leading-tight opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-2 group-hover:translate-y-0">
                {industry.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

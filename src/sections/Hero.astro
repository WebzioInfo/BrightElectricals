---
// ============================================================
// Hero.astro — Cinematic full-bleed industrial hero
// Centered layout, left-gradient shadow, technical grids, vignette & bloom
// Full-width White Trust Bar below the Hero
// ============================================================
import { company } from '@data/company';
---

<section
  id="hero"
  class="hero-root relative w-full min-h-[100svh] flex flex-col justify-center bg-[#0C1A2A]"
  aria-label="Home Hero section"
>

  <!-- ── FULL-BLEED BACKGROUND IMAGE & TECHNICAL GRADIENTS ────── -->
  <div class="absolute inset-0 z-0 overflow-hidden select-none pointer-events-none" aria-hidden="true">
    <img
      src="/images/hero-cinematic.webp"
      alt="Industrial electrical installation engineering works background"
      width="1920"
      height="1080"
      class="hero-bg-img w-full h-full object-cover object-center filter brightness-[0.55] contrast-[1.02]"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    
    <!-- Dark blue gradient from LEFT only (40-60%), right side image remains visible -->
    <div class="absolute inset-0" style="background-image: linear-gradient(to right, #0C1A2A 0%, rgba(12,26,42,0.98) 35%, rgba(12,26,42,0.85) 50%, rgba(12,26,42,0.3) 65%, rgba(12,26,42,0) 100%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[#0C1A2A] to-transparent"></div>
    
    <!-- Vignette & Technical Overlays -->
    <div class="absolute inset-0 hero-vignette"></div>
    <div class="absolute inset-0 blueprint-grid opacity-[0.035]"></div>
    <div class="absolute inset-0 noise-overlay opacity-[0.025]"></div>
    
    <!-- Light Bloom behind text -->
    <div class="absolute left-[10%] top-[30%] w-[450px] h-[450px] bg-teal-800/10 rounded-full blur-[100px] hero-light-radial"></div>
  </div>

  <!-- ── CONTENT CONTAINER (Centered Vertically and Horizontally) ── -->
  <div class="container relative z-10 w-full max-w-4xl mx-auto px-6 flex flex-col justify-center flex-grow pt-28 pb-28 md:pt-32 md:pb-32">
    <div class="flex flex-col items-center text-center hero-content-box">
      
      <!-- Headline -->
      <h1 class="font-display font-900 text-white leading-[1.03] tracking-tighter mb-6 max-w-3xl hero-headline hero-anim-item text-center">
        Engineering <br/>
        You Can Trust.
      </h1>

      <!-- 2-line Description -->
      <p class="text-white/60 text-base md:text-lg max-w-xl leading-relaxed mb-10 hero-anim-item text-center mx-auto">
        Kerala's licensed electrical contractors delivering KEB-compliant installations, heavy-duty industrial switchgear, and 24/7 priority emergency support.
      </p>

      <!-- Buttons -->
      <div class="flex flex-wrap items-center justify-center gap-6 hero-anim-item mx-auto">
        <a
          href="/contact/"
          class="btn btn-rect bg-teal-800 text-white hover:bg-teal-900 shadow-lg text-sm font-semibold animate-glow"
          aria-label="Request engineering consultation"
        >
          Request Consultation
        </a>
        <a
          href="/services/"
          class="text-xs uppercase tracking-widest font-bold text-white/60 hover:text-white transition-colors flex items-center gap-1.5 group"
          aria-label="Explore services"
        >
          Explore Services
          <span class="group-hover:translate-x-1 transition-transform inline-block" aria-hidden="true">→</span>
        </a>
      </div>

    </div>
  </div>

  <!-- ── SCROLL DOWN PROMPT ────────────────────────────────────── -->
  <div class="scroll-ind absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden lg:flex flex-col items-center gap-2 select-none pointer-events-none opacity-0" aria-hidden="true" id="hero-scroll-ind">
    <span style="font-size: 0.5625rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.35);">Scroll</span>
    <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.1); border-radius: 99px; position: relative; overflow: hidden;">
      <div class="scroll-dot" style="position: absolute; top: -6px; left: 50%; transform: translateX(-50%); width: 2.5px; height: 6px; border-radius: 99px; background: var(--brand-accent);"></div>
    </div>
  </div>

</section>

<!-- ── PREMIUM FULL-WIDTH TRUST BAR ─────────────────────────── -->
<section class="trust-bar-section w-full bg-white border-t border-b border-slate-900/5 py-6">
  <div class="trust-bar-container mx-auto w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
    
    <!-- Item 1 -->
    <div class="trust-col">
      <div class="w-11 h-11 rounded-full bg-teal-800/10 text-teal-800 flex items-center justify-center flex-shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <span class="text-sm md:text-base font-bold tracking-tight text-slate-800 whitespace-nowrap">Licensed KEB Engineers</span>
    </div>

    <!-- Item 2 -->
    <div class="trust-col">
      <div class="w-11 h-11 rounded-full bg-teal-800/10 text-teal-800 flex items-center justify-center flex-shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <span class="text-sm md:text-base font-bold tracking-tight text-slate-800 whitespace-nowrap">30+ Years Experience</span>
    </div>

    <!-- Item 3 -->
    <div class="trust-col">
      <div class="w-11 h-11 rounded-full bg-teal-800/10 text-teal-800 flex items-center justify-center flex-shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <span class="text-sm md:text-base font-bold tracking-tight text-slate-800 whitespace-nowrap">500+ Projects Completed</span>
    </div>

    <!-- Item 4 -->
    <div class="trust-col">
      <div class="w-11 h-11 rounded-full bg-teal-800/10 text-teal-800 flex items-center justify-center flex-shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.1a16 16 0 006 6l1.41-1.41a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15z"/>
        </svg>
      </div>
      <span class="text-sm md:text-base font-bold tracking-tight text-slate-800 whitespace-nowrap">24/7 Emergency Support</span>
    </div>

  </div>
</section>

<!-- ── STYLES ─────────────────────────────────────────────────────── -->
<style>
  .hero-root {
    min-height: 100svh;
    background: #0C1A2A;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 6.5vw + 0.5rem, 5rem);
  }

  /* Blueprint Grid overlay */
  .blueprint-grid {
    background-image: 
      linear-gradient(rgba(59, 130, 246, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: center;
    mask-image: radial-gradient(ellipse 80% 75% at 50% 50%, black 40%, transparent 100%);
  }

  /* Soft Vignette */
  .hero-vignette {
    background: radial-gradient(circle, transparent 50%, rgba(12,26,42,0.4) 100%);
  }

  /* Fine noise overlay */
  .noise-overlay {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* GPU accelerated slow zoom background animation */
  @keyframes slow-zoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.025); }
  }
  .hero-bg-img {
    will-change: transform;
    animation: slow-zoom 15s cubic-bezier(0.1, 0.8, 0.2, 1) forwards;
  }

  /* Bloom light breath */
  @keyframes bloom-breathe {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.04); }
  }
  .hero-light-radial {
    animation: bloom-breathe 8s ease-in-out infinite alternate;
  }

  /* Content entrance animations using keyframes to guarantee no-JS fallback visibility */
  @keyframes fade-up-in {
    from {
      opacity: 0;
      transform: translate3d(0, 14px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .hero-anim-item {
    opacity: 0;
    transform: translateY(14px);
    animation: fade-up-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    will-change: transform, opacity;
  }

  .hero-anim-item:nth-child(1) { animation-delay: 0.1s; }
  .hero-anim-item:nth-child(2) { animation-delay: 0.25s; }
  .hero-anim-item:nth-child(3) { animation-delay: 0.4s; }

  /* Scroll indicator fade-in after 1s */
  @keyframes scroll-fade-in {
    to { opacity: 1; }
  }
  .scroll-ind {
    opacity: 0;
    animation: scroll-fade-in 0.6s ease-out forwards;
    animation-delay: 0.9s;
  }

  /* Scroll indicator dot animation */
  .scroll-dot {
    animation: scroll-fall 2.4s ease-in-out infinite;
  }
  @keyframes scroll-fall {
    0%   { top: -6px; opacity: 0; }
    15%  { opacity: 1; }
    80%  { opacity: 0.5; }
    100% { top: 100%; opacity: 0; }
  }

  /* ── TRUST BAR STYLES ─────────────────────────────────────── */
  .trust-bar-section {
    box-shadow: 0 4px 30px rgba(15, 23, 42, 0.02);
  }

  .trust-bar-container {
    padding-left: clamp(24px, 6vw, 120px);
    padding-right: clamp(24px, 6vw, 120px);
  }

  .trust-col {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-right: 1.5rem;
    border-right: 1px solid rgba(15, 23, 42, 0.06);
  }

  @media (min-width: 1024px) {
    .trust-col:last-child {
      border-right: none;
      padding-right: 0;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .trust-col:nth-child(2n) {
      border-right: none;
      padding-right: 0;
    }
  }

  @media (max-width: 639px) {
    .trust-col {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid rgba(15, 23, 42, 0.04);
      padding-bottom: 1.25rem;
    }
    .trust-col:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim-item {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .scroll-ind {
      animation: none !important;
      opacity: 1 !important;
    }
    .scroll-dot {
      animation: none !important;
    }
    .hero-bg-img {
      animation: none !important;
    }
  }
</style>

<!-- ── SCRIPT ─────────────────────────────────────────────────────── -->
<script>
  function initHeroReveal() {
    const hero = document.getElementById('hero');
    const scrollInd = document.getElementById('hero-scroll-ind');
    if (!hero) return;

    // Trigger animations
    void hero.offsetHeight; // force reflow
    hero.classList.add('loaded');

    if (scrollInd) {
      setTimeout(() => {
        scrollInd.style.transition = 'opacity 0.6s ease-out';
        scrollInd.style.opacity = '1';
      }, 900);
    }
  }

  initHeroReveal();
  document.addEventListener('astro:page-load', initHeroReveal);
</script>

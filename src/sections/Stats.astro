---
// ============================================================
// Stats.astro — Engineering Panel
// Full-width cinematic image with overlaid stats strip
// ============================================================
---

<section
  class="eng-panel relative overflow-hidden"
  aria-label="Engineering excellence"
>
  <!-- Background image with parallax -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src="/images/hero-panel.jpg"
      alt=""
      width="1920"
      height="800"
      class="eng-bg w-full h-full object-cover"
      loading="lazy"
      decoding="async"
      style="transform: scale(1.06);"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, var(--deep-navy) 0%, rgba(12,26,42,0.6) 40%, rgba(12,26,42,0.7) 70%, var(--deep-navy) 100%);" />
    <div class="absolute inset-0 texture-noise" />
  </div>

  <!-- Content -->
  <div class="relative z-10 container flex flex-col items-center justify-center text-center" style="padding-block: clamp(5rem, 12vw, 10rem);">

    <!-- Statement -->
    <p class="reveal" style="font-family: var(--font-display); font-weight: 300; font-size: clamp(1.5rem, 3.5vw, 2.75rem); letter-spacing: -0.02em; line-height: 1.35; color: #F1F5F9; max-width: 700px; margin-bottom: clamp(2.5rem, 5vw, 4rem);">
      Engineering excellence,<br />
      <span style="color: var(--brand-accent-lt); font-weight: 500;">delivered.</span>
    </p>

    <!-- Stats strip -->
    <div
      class="grid grid-cols-2 lg:grid-cols-4 w-full max-w-4xl"
      style="gap: 1px; background: rgba(148,163,184,0.12); border-radius: var(--radius-lg); overflow: hidden;"
      role="list"
      aria-label="Key statistics"
    >
      <div class="stat-cell reveal" style="transition-delay: 0ms">
        <span class="stat-val" data-counter="500">0</span><span class="stat-suf">+</span>
        <span class="stat-lbl">Projects Delivered</span>
      </div>
      <div class="stat-cell reveal" style="transition-delay: 100ms">
        <span class="stat-val" data-counter="12">0</span><span class="stat-suf">+</span>
        <span class="stat-lbl">Years Experience</span>
      </div>
      <div class="stat-cell reveal" style="transition-delay: 200ms">
        <span class="stat-val">24</span><span class="stat-suf">/7</span>
        <span class="stat-lbl">Emergency Support</span>
      </div>
      <div class="stat-cell reveal" style="transition-delay: 300ms">
        <span class="stat-val">100</span><span class="stat-suf">%</span>
        <span class="stat-lbl">Safety Compliance</span>
      </div>
    </div>

  </div>
</section>

<style>
  .eng-panel {
    min-height: clamp(400px, 55vw, 600px);
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2vw, 2rem);
    background: rgba(12, 26, 42, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .stat-val {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.04em;
    line-height: 1;
    color: #F1F5F9;
  }

  .stat-suf {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--brand-accent);
    line-height: 1;
  }

  .stat-lbl {
    display: block;
    margin-top: 0.5rem;
    font-size: clamp(0.625rem, 0.9vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748B;
  }
</style>

<script>
  // Counter animation for stats
  function initCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
    counters.forEach((counter) => {
      const target = parseInt(counter.dataset.counter ?? '0', 10);
      const duration = 2000;
      const step = target / (duration / 16);
      let current = 0;
      let started = false;

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            const tick = () => {
              current = Math.min(current + step, target);
              counter.textContent = Math.floor(current).toLocaleString('en-IN');
              if (current < target) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      obs.observe(counter);
    });
  }

  initCounters();
  document.addEventListener('astro:page-load', initCounters);
</script>

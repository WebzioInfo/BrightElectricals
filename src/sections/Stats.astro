---
// ============================================================
// Stats.astro — Engineering Panel (Redesigned)
// Option B — Warm light gray, concrete/blueprint aesthetics
// Editorial asymmetrical layout, minimal blueprint cards
// ============================================================
---

<section
  class="section bg-warm-2 texture-blueprint relative overflow-hidden"
  style="border-top: 1px solid var(--concrete); border-bottom: 1px solid var(--concrete);"
  aria-label="Engineering performance and statistics"
>
  <!-- Decorative Technical Accents -->
  <div class="absolute inset-0 pointer-events-none opacity-40 select-none" aria-hidden="true">
    <!-- Fine corner crosshairs (architectural blueprint details) -->
    <div class="absolute top-8 left-8 w-4 h-4 border-t border-l border-concrete-dark"></div>
    <div class="absolute top-8 right-8 w-4 h-4 border-t border-r border-concrete-dark"></div>
    <div class="absolute bottom-8 left-8 w-4 h-4 border-b border-l border-concrete-dark"></div>
    <div class="absolute bottom-8 right-8 w-4 h-4 border-b border-r border-concrete-dark"></div>
    <!-- Technical coordinate labels -->
    <span class="absolute top-4 left-1/2 -translate-x-1/2 text-[9px] font-mono tracking-widest text-concrete-dark">SYS.COORD / 11.23.09</span>
  </div>

  <div class="container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left Column: Editorial Statement -->
      <div class="lg:col-span-5 reveal">
        <span class="section-label mb-4" style="color: var(--brand-primary); font-size: 0.6875rem; letter-spacing: 0.14em;">Performance Metrics</span>
        <h2
          class="heading-md mb-6"
          style="color: var(--text-primary); line-height: 1.1; letter-spacing: -0.03em;"
        >
          Precision Engineering,<br />
          <span class="gradient-text">Quantified.</span>
        </h2>
        <p style="font-size: clamp(0.875rem, 1.1vw, 1rem); line-height: 1.75; color: var(--text-secondary); max-width: 420px; margin-bottom: 2rem;">
          Our legacy is built on measurable standards. From voltage regulation to emergency response times, we track every parameter to guarantee absolute safety and performance.
        </p>
        <!-- Subtle schematic accent line -->
        <div class="hidden lg:block w-32 h-[1px] bg-concrete-dark relative">
          <div class="absolute right-0 -top-[2px] w-1.5 h-1.5 rounded-full bg-brand-accent"></div>
        </div>
      </div>

      <!-- Right Column: Asymmetrical Architectural Blueprint Cards -->
      <div class="lg:col-span-7">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5" role="list">
          
          <!-- Stat Card 1 -->
          <div
            class="stat-bp-card card-light p-6 lg:p-8 flex flex-col justify-between reveal"
            style="min-height: 180px; border-left: 3px solid var(--brand-primary);"
            role="listitem"
          >
            <div>
              <span class="stat-bp-tag">REF.01 / VOLTS</span>
              <h3 class="stat-bp-num mt-2">
                <span data-counter="500">0</span><span class="stat-bp-suf">+</span>
              </h3>
            </div>
            <p class="stat-bp-lbl">Projects Successfully Commissioned</p>
          </div>

          <!-- Stat Card 2 -->
          <div
            class="stat-bp-card card-light p-6 lg:p-8 flex flex-col justify-between reveal delay-100"
            style="min-height: 180px; border-left: 3px solid var(--brand-accent);"
            role="listitem"
          >
            <div>
              <span class="stat-bp-tag">REF.02 / DURATION</span>
              <h3 class="stat-bp-num mt-2">
                <span data-counter="30">0</span><span class="stat-bp-suf">+</span>
              </h3>
            </div>
            <p class="stat-bp-lbl">Years of Certified Engineering Excellence</p>
          </div>

          <!-- Stat Card 3 -->
          <div
            class="stat-bp-card card-light p-6 lg:p-8 flex flex-col justify-between reveal delay-150"
            style="min-height: 180px; border-left: 3px solid #22C55E;"
            role="listitem"
          >
            <div>
              <span class="stat-bp-tag">REF.03 / SLA</span>
              <h3 class="stat-bp-num mt-2">
                <span>24</span><span class="stat-bp-suf">/7</span>
              </h3>
            </div>
            <p class="stat-bp-lbl">Rapid Dispatch Emergency Response SLA</p>
          </div>

          <!-- Stat Card 4 -->
          <div
            class="stat-bp-card card-light p-6 lg:p-8 flex flex-col justify-between reveal delay-200"
            style="min-height: 180px; border-left: 3px solid #EAB308;"
            role="listitem"
          >
            <div>
              <span class="stat-bp-tag">REF.04 / AUDIT</span>
              <h3 class="stat-bp-num mt-2">
                <span>100</span><span class="stat-bp-suf">%</span>
              </h3>
            </div>
            <p class="stat-bp-lbl">Compliance Rating in Safety Audits</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Asymmetric Blueprint Card Aesthetics */
  .stat-bp-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.35s var(--ease-spring);
    position: relative;
    border-radius: var(--radius-md) !important;
  }
  .stat-bp-card::after {
    content: '';
    position: absolute;
    top: 6px;
    right: 6px;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--concrete-dark);
  }
  .stat-bp-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    background: #ffffff;
  }

  .stat-bp-tag {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .stat-bp-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.25rem, 4vw, 3rem);
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-primary);
  }

  .stat-bp-suf {
    color: var(--brand-accent);
    font-weight: 700;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-left: 0.05em;
  }

  .stat-bp-lbl {
    font-size: 0.8125rem;
    line-height: 1.5;
    font-weight: 500;
    color: var(--text-secondary);
    margin-top: 1rem;
    border-top: 1px solid var(--concrete);
    padding-top: 0.75rem;
  }
</style>

<script>
  function initCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
    
    counters.forEach((counter) => {
      const target = parseInt(counter.dataset.counter ?? '0', 10);
      const duration = 2000;
      const step = target / (duration / 16);
      let current = 0;
      let started = false;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            const tick = () => {
              current = Math.min(current + step, target);
              counter.textContent = Math.floor(current).toLocaleString('en-IN');
              if (current < target) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });

      observer.observe(counter);
    });
  }

  initCounters();
  document.addEventListener('astro:page-load', initCounters);
</script>

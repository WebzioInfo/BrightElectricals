---
// ============================================================
// WhyChooseUs.astro — Dark feature grid with circuit decoration
// ============================================================

const features = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Licensed & Certified',
    desc: 'Every electrician holds valid KEB certifications and undergoes continuous safety training.',
  },
  {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    title: '24/7 Emergency Response',
    desc: 'Rapid-response team available around the clock. Electrical emergencies never wait — neither do we.',
  },
  {
    icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
    title: 'Premium Materials',
    desc: 'Only ISI-marked, brand-certified components. Every installation is engineered to last decades.',
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    title: 'Experienced Team',
    desc: 'Over 12 years of collective experience across residential, commercial, and industrial sectors.',
  },
  {
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Transparent Pricing',
    desc: 'Detailed quotations before work begins. Competitive rates with zero hidden charges.',
  },
  {
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Pan-Kerala Coverage',
    desc: 'Based in Nilambur, serving clients across all of Kerala — Malappuram, Kozhikode, Thrissur, Kochi, and beyond.',
  },
];
---

<section
  class="section bg-dark texture-circuit"
  aria-labelledby="why-heading"
>
  <div class="container relative z-10">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto" style="margin-bottom: clamp(3rem, 6vw, 5rem);">
      <p class="section-label section-label-light mb-4 reveal">Why Choose Us</p>
      <h2
        id="why-heading"
        class="heading-lg text-white mb-5 reveal delay-100"
      >
        Built on Trust.<br />Driven by Excellence.
      </h2>
      <p class="reveal delay-200" style="font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); line-height: 1.8; color: #94A3B8; max-width: 520px; margin-inline: auto;">
        Over a decade serving Kerala with reliability, safety, and workmanship
        that speaks for itself.
      </p>
    </div>

    <!-- Feature grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
      style="gap: clamp(0.75rem, 1.5vw, 1.25rem);"
      role="list"
      aria-label="Our key strengths"
    >
      {features.map((feat, i) => (
        <div
          class="why-card card-dark p-6 lg:p-8 reveal"
          style={`transition-delay: ${(i % 3) * 80}ms`}
          role="listitem"
        >
          <!-- Icon -->
          <div class="icon-box icon-box-dark mb-5" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={feat.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3
            class="font-display font-700 text-white mb-3"
            style="font-size: clamp(1rem, 1.3vw, 1.125rem); letter-spacing: -0.01em;"
          >
            {feat.title}
          </h3>

          <!-- Description -->
          <p style="font-size: clamp(0.8125rem, 1vw, 0.875rem); line-height: 1.7; color: #64748B;">
            {feat.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex flex-wrap justify-center gap-3 reveal" style="margin-top: clamp(2.5rem, 5vw, 4rem);">
      <a href="/about/" class="btn btn-rect btn-accent">
        Our Story
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </a>
      <a href="/contact/" class="btn btn-rect btn-outline-light">
        Get Free Estimate
      </a>
    </div>

  </div>
</section>

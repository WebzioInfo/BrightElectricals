---
// ContactCTA.astro — Pre-footer contact call-to-action banner
import { company } from '@data/company';
---

<section
  class="relative py-20 lg:py-28 bg-brand-primary overflow-hidden"
  aria-labelledby="cta-heading"
>
  <!-- Background decoration -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-grid opacity-10" />
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-accent/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" />
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-white/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/2" />
  </div>

  <div class="container relative z-10 text-center">
    <!-- Badge -->
    <div class="badge badge-white mx-auto mb-6 reveal">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse" aria-hidden="true" />
      Free Estimates · No Obligation
    </div>

    <!-- Headline -->
    <h2
      id="cta-heading"
      class="font-display font-900 text-white mb-4 reveal delay-100"
      style="font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.08;"
    >
      Ready to Upgrade Your<br />
      <span class="text-brand-accent-light">Electrical Systems?</span>
    </h2>

    <p class="text-white/70 text-lg leading-relaxed max-w-xl mx-auto mb-10 reveal delay-200">
      Get a free, no-obligation site assessment and detailed quote. Our team typically responds within 2 hours.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center reveal delay-300">
      <a
        href="/contact/"
        class="btn btn-lg btn-white"
        id="cta-quote-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Get Free Quote
      </a>
      <a
        href={company.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-lg btn-whatsapp"
        id="cta-whatsapp-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Us Now
      </a>
      <a
        href={`tel:${company.phone}`}
        class="btn btn-lg btn-ghost-white"
        aria-label={`Call us at ${company.phoneDisplay}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.1a16 16 0 006 6l1.41-1.41a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15z"/>
        </svg>
        {company.phoneDisplay}
      </a>
    </div>

    <!-- Small trust note -->
    <p class="text-white/40 text-xs mt-8 reveal delay-400">
      Typically responds within 2 hours · Available 24/7 for emergencies · Serving all of Kerala
    </p>
  </div>
</section>

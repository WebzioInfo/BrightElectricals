---
// ============================================================
// services/index.astro — Services listing page
// ============================================================
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@sections/ContactCTA.astro';
import { services } from '@data/services';
import { company } from '@data/company';
import { pageSEO } from '@data/seo';
import { buildBreadcrumbSchema } from '@lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: company.site.url + '/' },
  { name: 'Services', url: company.site.url + '/services/' },
]);
---

<BaseLayout seo={pageSEO.services} jsonLd={[breadcrumb]}>

  <!-- Hero -->
  <section class="relative pt-36 pb-20 lg:pt-44 lg:pb-28 bg-brand-primary overflow-hidden" aria-labelledby="services-page-heading">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 bg-grid opacity-10" />
      <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" />
    </div>
    <div class="container relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/50">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="text-white/90" aria-current="page">Services</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <p class="section-label text-brand-accent mb-3">What We Offer</p>
        <h1
          id="services-page-heading"
          class="font-display font-900 text-white mb-4"
          style="font-size: clamp(2.25rem, 5vw, 3.75rem); letter-spacing: -0.03em; line-height: 1.08;"
        >
          Complete Electrical Services in Kerala
        </h1>
        <p class="text-white/70 text-lg leading-relaxed">
          From domestic wiring to industrial power systems — all your electrical needs under one roof, delivered by licensed professionals.
        </p>
      </div>
    </div>
  </section>

  <!-- Services list -->
  <section class="section bg-surface-50" aria-label="All services">
    <div class="container">
      <div class="space-y-8">
        {services.map((service, i) => {
          const isEven = i % 2 === 0;
          return (
            <article
              id={service.id}
              class={`card overflow-hidden grid grid-cols-1 lg:grid-cols-2 reveal scroll-mt-24`}
              aria-labelledby={`service-${service.id}-title`}
            >
              <!-- Image -->
              <div class={`relative h-64 lg:h-auto min-h-[280px] bg-surface-100 ${!isEven ? 'lg:order-last' : ''}`}>
                <img
                  src={service.image}
                  alt={`${service.title} — Bright Electrical Kerala`}
                  width="600"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-brand-dark/40 to-transparent" aria-hidden="true" />
              </div>

              <!-- Content -->
              <div class="p-8 lg:p-10 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-4">
                  <div class="icon-box" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={service.icon} />
                    </svg>
                  </div>
                  <span class="section-label">{service.shortTitle}</span>
                </div>

                <h2
                  id={`service-${service.id}-title`}
                  class="font-display font-800 text-surface-900 mb-3"
                  style="font-size: clamp(1.5rem, 2.5vw, 2rem); letter-spacing: -0.025em; line-height: 1.15;"
                >
                  {service.title}
                </h2>
                <p class="text-surface-500 leading-relaxed mb-6">{service.longDesc}</p>

                <!-- Features -->
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-6" aria-label={`${service.title} features`}>
                  {service.features.map(feat => (
                    <li class="flex items-start gap-2 text-sm text-surface-600">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent mt-0.5 flex-shrink-0" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      {feat}
                    </li>
                  ))}
                </ul>

                <!-- Industries badge list -->
                <div class="flex flex-wrap gap-2 mb-6">
                  {service.industries.map(ind => (
                    <span class="badge badge-primary">{ind}</span>
                  ))}
                </div>

                <a
                  href={`/contact/?service=${encodeURIComponent(service.title)}`}
                  class="btn btn-primary w-fit"
                  aria-label={`Enquire about ${service.title}`}
                >
                  Get a Quote
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>

  }

  /* Radial ambient glow lighting */
  .radial-glow {
    background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.05) 0%, transparent 60%);
  }
  .radial-glow-teal {
    background: radial-gradient(circle at 10% 20%, rgba(13, 79, 92, 0.12) 0%, transparent 70%);
  }

  /* ─── Animation Timelines (Native Scroll-Driven Animations) ─── */
  @keyframes reveal-in-native {
    0% {
      opacity: 0;
      transform: translateY(60px) scale(0.97);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes reveal-left-native {
    0% {
      opacity: 0;
      transform: translateX(-60px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes reveal-right-native {
    0% {
      opacity: 0;
      transform: translateX(60px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes reveal-scale-native {
    0% {
      opacity: 0;
      transform: scale(0.93);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Apply scroll-driven animations natively if supported */
  .scroll-active-trigger.native-sda.reveal-in {
    animation: reveal-in-native linear both;
    animation-timeline: view();
    animation-range: entry 10% cover 30%;
  }
  .scroll-active-trigger.native-sda.reveal-left {
    animation: reveal-left-native linear both;
    animation-timeline: view();
    animation-range: entry 10% cover 30%;
  }
  .scroll-active-trigger.native-sda.reveal-right {
    animation: reveal-right-native linear both;
    animation-timeline: view();
    animation-range: entry 10% cover 30%;
  }
  .scroll-active-trigger.native-sda.reveal-scale {
    animation: reveal-scale-native linear both;
    animation-timeline: view();
    animation-range: entry 10% cover 30%;
  }

  /* ─── Fallback styles for older browsers without CSS Animation Timelines ─── */
  .scroll-active-trigger:not(.native-sda) {
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .scroll-active-trigger.reveal-in:not(.native-sda) {
    transform: translateY(50px);
  }
  .scroll-active-trigger.reveal-left:not(.native-sda) {
    transform: translateX(-50px);
  }
  .scroll-active-trigger.reveal-right:not(.native-sda) {
    transform: translateX(50px);
  }
  .scroll-active-trigger.reveal-scale:not(.native-sda) {
    transform: scale(0.95);
  }

  /* Active class toggled by JS IntersectionObserver */
  .scroll-active-trigger.scroll-active:not(.native-sda) {
    opacity: 1;
    transform: translateY(0) translateX(0) scale(1);
  }
</style>

---
// ============================================================
// services/index.astro — Redesigned Services listing page
// Premium Editorial / Industrial aesthetic (ABB, Siemens style)
// ============================================================
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@sections/ContactCTA.astro';
import { services } from '@data/services';
import { company } from '@data/company';
import { pageSEO } from '@data/seo';
import { buildBreadcrumbSchema } from '@lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: company.site.url + '/' },
  { name: 'Services', url: company.site.url + '/services/' },
]);

// Map individual services for explicit custom layouts
const homeElectrical = services.find(s => s.id === 'home-electrical')!;
const industrialPower = services.find(s => s.id === 'industrial-power')!;
const atsPanels = services.find(s => s.id === 'ats-amf-panels')!;
const automation = services.find(s => s.id === 'automation-smart-control')!;
const cabling = services.find(s => s.id === 'structured-cabling')!;
const security = services.find(s => s.id === 'cctv-security')!;
const maintenance = services.find(s => s.id === 'repair-maintenance')!;
---

<BaseLayout seo={pageSEO.services} jsonLd={[breadcrumb]}>
  
  <!-- HERO SECTION -->
  <section class="hero-section relative overflow-hidden bg-dark blueprint-bg flex items-center justify-center border-b border-white/5" aria-labelledby="services-hero-title">
    <div class="absolute inset-0 radial-glow pointer-events-none" aria-hidden="none"></div>
    <div class="absolute inset-0 radial-glow-teal pointer-events-none" aria-hidden="none"></div>
    
    <div class="container relative z-10 text-center py-24 md:py-36 lg:py-48">
      <nav aria-label="Breadcrumb" class="mb-8 flex justify-center scroll-active-trigger reveal-in">
        <ol class="flex items-center gap-3 text-xs tracking-widest uppercase text-white/40">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-white/20">/</li>
          <li class="text-white/80" aria-current="page">Services</li>
        </ol>
      </nav>
      
      <p class="section-label section-label-light mb-6 scroll-active-trigger reveal-in delay-100">Engineering Solutions</p>
      
      <h1 id="services-hero-title" class="heading-xl text-white tracking-tighter mb-8 max-w-4xl mx-auto scroll-active-trigger reveal-scale delay-150">
        Industrial Grade. <br/>
        <span class="text-white/60">Architectural Precision.</span>
      </h1>
      
      <p class="text-white/60 text-base md:text-lg max-w-2xl mx-auto leading-relaxed mb-12 scroll-active-trigger reveal-in delay-200">
        From domestic infrastructure upgrades to heavy-duty industrial installations — we build, automate, and secure complete power systems.
      </p>
      
      <!-- Scroll indicator -->
      <div class="flex justify-center mt-6 scroll-active-trigger reveal-in delay-300" aria-hidden="true">
        <a href="#home-solutions" class="group flex flex-col items-center gap-3 text-xs tracking-widest uppercase text-white/30 hover:text-white transition-colors">
          Explore Chapters
          <div class="w-[1px] h-12 bg-white/20 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1/2 bg-white group-hover:translate-y-full transition-transform duration-1000 ease-in-out"></div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CHAPTER 1: HOME ELECTRICAL SOLUTIONS -->
  <section id="home-solutions" class="section bg-warm border-b border-black/5" aria-labelledby="chapter-1-title">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left Side: Editorial Content -->
        <div class="lg:col-span-6 scroll-active-trigger reveal-left">
          <span class="chapter-indicator text-xs tracking-widest text-teal-800 font-bold block mb-4">01 // DOMESTIC INFRASTRUCTURE</span>
          <h2 id="chapter-1-title" class="heading-lg text-slate-900 mb-6 font-display font-800">
            {homeElectrical.title}
          </h2>
          <p class="text-slate-600 text-base md:text-lg leading-relaxed mb-8">
            {homeElectrical.longDesc}
          </p>
          
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8" aria-label="Domestic services features">
            {homeElectrical.features.map((feat) => (
              <li class="flex items-start gap-3 text-sm text-slate-700 font-medium">
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-teal-50 text-teal-700 flex-shrink-0 mt-0.5" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                </span>
                {feat}
              </li>
            ))}
          </ul>
          
          <div class="flex flex-wrap gap-2 mb-8">
            {homeElectrical.industries.map((ind) => (
              <span class="px-3.5 py-1 text-[10px] tracking-wider font-semibold uppercase rounded bg-slate-100 text-slate-600 border border-slate-200/50">{ind}</span>
            ))}
          </div>

          <a 
            href={`/contact/?service=${encodeURIComponent(homeElectrical.title)}`} 
            class="btn btn-rect bg-teal-800 text-white hover:bg-teal-900 shadow-md inline-flex items-center"
            aria-label={`Enquire about ${homeElectrical.title}`}
          >
            Request Engineering Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        
        <!-- Right Side: Architectural Overlapping Image -->
        <div class="lg:col-span-6 relative scroll-active-trigger reveal-right delay-100">
          <div class="relative z-10 rounded-lg overflow-hidden border border-slate-900/10 shadow-2xl scale-95 lg:scale-100 transition-transform duration-500 hover:scale-[1.02]">
            <img 
              src={homeElectrical.image} 
              alt="High-end domestic electrical install" 
              class="w-full object-cover aspect-[4/3] filter brightness-[0.93] contrast-[1.05]"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
          </div>
          <!-- Decorative wireframe blueprint backing -->
          <div class="absolute -inset-4 border border-dashed border-teal-800/20 rounded-lg -z-0 pointer-events-none" aria-hidden="true"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- CHAPTER 2: INDUSTRIAL POWER SYSTEMS -->
  <section id="industrial-solutions" class="section bg-dark blueprint-bg border-b border-white/5" aria-labelledby="chapter-2-title">
    <div class="absolute inset-0 radial-glow pointer-events-none" aria-hidden="none"></div>
    <div class="container relative z-10">
      
      <!-- Typography Header -->
      <div class="mb-16 max-w-3xl scroll-active-trigger reveal-in">
        <span class="chapter-indicator text-xs tracking-widest text-teal-400 font-bold block mb-4">02 // HEAVY INDUSTRY</span>
        <h2 id="chapter-2-title" class="heading-lg text-white mb-6">
          {industrialPower.title}
        </h2>
        <p class="text-white/60 text-base md:text-lg">
          {industrialPower.longDesc}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-stretch">
        
        <!-- Left Column: Heavy spec listings & stats -->
        <div class="lg:col-span-5 flex flex-col justify-between scroll-active-trigger reveal-left">
          <div class="space-y-6">
            <h3 class="text-xs uppercase tracking-widest font-bold text-white/50 border-b border-white/10 pb-3">Engineering Specifications</h3>
            
            <div class="grid grid-cols-2 gap-6 text-sm">
              <div>
                <p class="text-white/40 mb-1">Max Load Capacity</p>
                <p class="text-white font-bold text-lg">Up to 11KV Systems</p>
              </div>
              <div>
                <p class="text-white/40 mb-1">Compliance Standards</p>
                <p class="text-white font-bold text-lg">CEA & KEB Standards</p>
              </div>
              <div>
                <p class="text-white/40 mb-1">Panel Capability</p>
                <p class="text-white font-bold text-lg">MCC, PCC Boards</p>
              </div>
              <div>
                <p class="text-white/40 mb-1">Testing Cycle</p>
                <p class="text-white font-bold text-lg">Comprehensive (FLIR)</p>
              </div>
            </div>

            <div class="border-t border-white/10 pt-6">
              <h4 class="text-xs uppercase tracking-widest font-bold text-white/50 mb-4">Included Solutions</h4>
              <ul class="space-y-3" aria-label="Industrial systems solutions list">
                {industrialPower.features.map(feat => (
                  <li class="flex items-center gap-3 text-sm text-white/80">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)]" aria-hidden="true"></span>
                    {feat}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="mt-10 lg:mt-0 pt-6">
            <a 
              href={`/contact/?service=${encodeURIComponent(industrialPower.title)}`} 
              class="btn btn-rect bg-white text-slate-900 hover:bg-slate-100 shadow-xl inline-flex items-center w-fit"
              aria-label={`Inquire about ${industrialPower.title}`}
            >
              Request Infrastructure Proposal
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right Column: Full-width feeling architectural crop -->
        <div class="lg:col-span-7 flex items-center scroll-active-trigger reveal-right delay-150">
          <div class="relative w-full h-full min-h-[350px] rounded-lg overflow-hidden border border-white/10 group">
            <img 
              src={industrialPower.image} 
              alt="Industrial electrical panels" 
              class="w-full h-full object-cover filter brightness-[0.75] contrast-[1.1] transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>
            
            <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end">
              <div>
                <p class="text-[10px] tracking-widest text-teal-400 font-bold uppercase mb-1">Live Deployment</p>
                <h4 class="text-white text-sm font-semibold tracking-tight">Industrial Plant Distribution</h4>
              </div>
              <div class="flex gap-2">
                {industrialPower.industries.slice(0, 2).map(ind => (
                  <span class="px-2 py-0.5 text-[9px] tracking-wider uppercase bg-white/10 border border-white/20 text-white/90 rounded">{ind}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CHAPTER 3: ATS & AMF PANEL SETUP -->
  <section id="backup-solutions" class="section bg-warm-2 border-b border-black/5" aria-labelledby="chapter-3-title">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        
        <!-- Left Side: Editorial / Context -->
        <div class="lg:col-span-5 scroll-active-trigger reveal-left">
          <span class="chapter-indicator text-xs tracking-widest text-slate-800 font-bold block mb-4">03 // POWER BACKUP SYSTEMS</span>
          <h2 id="chapter-3-title" class="heading-lg text-slate-900 mb-6">
            {atsPanels.title}
          </h2>
          <p class="text-slate-600 text-base md:text-lg leading-relaxed mb-8">
            {atsPanels.longDesc}
          </p>
          
          <div class="bg-white/50 border border-slate-950/5 rounded-lg p-6 mb-8">
            <h4 class="text-xs uppercase tracking-widest font-bold text-slate-700 mb-3">Critical Target Sectors</h4>
            <div class="flex flex-wrap gap-2">
              {atsPanels.industries.map(ind => (
                <span class="px-3 py-1 text-[10px] tracking-wider font-semibold uppercase rounded bg-teal-50 text-teal-800 border border-teal-100">{ind}</span>
              ))}
            </div>
          </div>

          <a 
            href={`/contact/?service=${encodeURIComponent(atsPanels.title)}`} 
            class="btn btn-rect bg-slate-900 text-white hover:bg-slate-800 shadow-md inline-flex items-center"
            aria-label={`Enquire about ${atsPanels.title}`}
          >
            Design Backup System
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        
        <!-- Right Side: Clean Minimal Spec Sheet -->
        <div class="lg:col-span-7 scroll-active-trigger reveal-right delay-150">
          <div class="bg-white border border-slate-900/10 rounded-lg shadow-xl overflow-hidden">
            <div class="px-6 py-4 bg-slate-900 text-white flex justify-between items-center border-b border-slate-800">
              <span class="text-xs uppercase tracking-widest font-bold text-white/70">ATS-AMF Specifications</span>
              <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold tracking-wider text-teal-400 bg-teal-950/40 border border-teal-900/50 px-2 py-0.5 rounded">
                <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse" aria-hidden="true"></span> ACTIVE CERTIFIED
              </span>
            </div>
            
            <div class="divide-y divide-slate-100">
              
              <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-2">
                <span class="text-xs uppercase tracking-wider font-semibold text-slate-400">Transfer Time</span>
                <span class="sm:col-span-2 text-sm text-slate-800 font-bold">Standard: &lt; 100ms switchover latency</span>
              </div>
              
              <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-2">
                <span class="text-xs uppercase tracking-wider font-semibold text-slate-400">Gen-Set Sync</span>
                <span class="sm:col-span-2 text-sm text-slate-800">Auto-start command line with pre-heat delay controller</span>
              </div>
              
              <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-2">
                <span class="text-xs uppercase tracking-wider font-semibold text-slate-400">Phase Monitoring</span>
                <span class="sm:col-span-2 text-sm text-slate-800">Over/Under voltage and phase-sequence mismatch cut-off</span>
              </div>

              <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-2">
                <span class="text-xs uppercase tracking-wider font-semibold text-slate-400">Diagnostics</span>
                <span class="sm:col-span-2 text-sm text-slate-800">Integrated LED display for live phase telemetry & fault history</span>
              </div>
              
            </div>

            <div class="p-6 bg-slate-50 border-t border-slate-100">
              <h4 class="text-xs uppercase tracking-widest font-bold text-slate-500 mb-3">Setup Includes</h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {atsPanels.features.map(feat => (
                  <span class="text-xs text-slate-700 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 text-teal-800 flex-shrink-0" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                    {feat}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CHAPTER 4: AUTOMATION & SMART CONTROL -->
  <section id="automation-solutions" class="section bg-slate-950 border-b border-white/5" aria-labelledby="chapter-4-title">
    <div class="absolute inset-0 radial-glow pointer-events-none" aria-hidden="none"></div>
    <div class="container relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left Side: Interactive System Flowchart SVG -->
        <div class="lg:col-span-6 scroll-active-trigger reveal-left">
          <div class="border border-white/10 rounded-lg p-6 bg-slate-900/60 backdrop-blur-md relative overflow-hidden">
            <h4 class="text-xs uppercase tracking-widest font-bold text-teal-400 mb-6">Automation Process Architecture</h4>
            
            <!-- Flow Diagram -->
            <div class="space-y-6 relative z-10">
              <div class="flex items-center justify-between p-3 bg-white/5 rounded border border-white/5">
                <span class="text-xs text-white/50 uppercase">Inputs</span>
                <span class="text-xs font-semibold text-white">Sensors / Voice / Mobile Trigger</span>
              </div>
              <div class="flex justify-center" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-teal-400 animate-bounce">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <polyline points="19 12 12 19 5 12"></polyline>
                </svg>
              </div>
              <div class="flex items-center justify-between p-3 bg-teal-950/40 rounded border border-teal-900/50">
                <span class="text-xs text-teal-400/80 uppercase font-semibold">Central Processor</span>
                <span class="text-xs font-bold text-white">PLC / IoT Gateway Hub</span>
              </div>
              <div class="flex justify-center" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-teal-400 animate-bounce">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <polyline points="19 12 12 19 5 12"></polyline>
                </svg>
              </div>
              <div class="flex items-center justify-between p-3 bg-white/5 rounded border border-white/5">
                <span class="text-xs text-white/50 uppercase">Outputs</span>
                <span class="text-xs font-semibold text-white">Lighting / HVAC / Machine Relay</span>
              </div>
            </div>

            <!-- Absolute decorative light source -->
            <div class="absolute -right-16 -top-16 w-32 h-32 bg-blue-600/10 rounded-full blur-2xl" aria-hidden="true"></div>
          </div>
        </div>

        <!-- Right Side: Narrative -->
        <div class="lg:col-span-6 scroll-active-trigger reveal-right delay-100">
          <span class="chapter-indicator text-xs tracking-widest text-teal-400 font-bold block mb-4">04 // SMART SYSTEM LOGIC</span>
          <h2 id="chapter-4-title" class="heading-lg text-white mb-6">
            {automation.title}
          </h2>
          <p class="text-white/60 text-base md:text-lg leading-relaxed mb-8">
            {automation.longDesc}
          </p>
          
          <ul class="space-y-4 mb-8" aria-label="Smart automation features">
            {automation.features.map(feat => (
              <li class="flex items-center gap-3 text-sm text-white/80 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.6)]" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                {feat}
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2 mb-8">
            {automation.industries.map(ind => (
              <span class="px-2.5 py-1 text-[9px] font-semibold tracking-wider uppercase rounded bg-white/5 border border-white/10 text-white/70">{ind}</span>
            ))}
          </div>

          <a 
            href={`/contact/?service=${encodeURIComponent(automation.title)}`} 
            class="btn btn-rect bg-teal-700 text-white hover:bg-teal-600 shadow-md inline-flex items-center"
            aria-label={`Enquire about ${automation.title}`}
          >
            Design Intelligent Control System
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- CHAPTER 5: STRUCTURED CABLING & NETWORKS -->
  <section id="network-solutions" class="section bg-warm border-b border-black/5" aria-labelledby="chapter-5-title">
    <div class="container">
      
      <!-- Asymmetrical Title Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 items-end scroll-active-trigger reveal-in">
        <div class="lg:col-span-7">
          <span class="chapter-indicator text-xs tracking-widest text-slate-800 font-bold block mb-4">05 // DATA INFRASTRUCTURE</span>
          <h2 id="chapter-5-title" class="heading-lg text-slate-900 font-display font-800">
            {cabling.title}
          </h2>
        </div>
        <div class="lg:col-span-5">
          <p class="text-slate-600 text-sm md:text-base leading-relaxed">
            {cabling.longDesc}
          </p>
        </div>
      </div>

      <!-- Asymmetrical Grid layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        
        <!-- Left large panel: Structured cabling spec card -->
        <div class="lg:col-span-7 bg-white border border-slate-900/10 rounded-lg p-8 shadow-lg flex flex-col justify-between scroll-active-trigger reveal-left">
          <div>
            <span class="text-[10px] tracking-widest uppercase font-bold text-teal-800 mb-4 block">Compliance & Topology</span>
            <h4 class="text-slate-900 font-bold text-xl mb-6">TIA/EIA Compliant Network Architecture</h4>
            
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-1.5 h-1.5 rounded-full bg-teal-800 mt-2 flex-shrink-0" aria-hidden="true"></div>
                <div>
                  <h5 class="text-sm font-bold text-slate-800">Cat6 / Cat6A Certified Cabling</h5>
                  <p class="text-xs text-slate-500 mt-1">Certified for gigabit speed and high-load transmission lanes with minimum cross-talk.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-1.5 h-1.5 rounded-full bg-teal-800 mt-2 flex-shrink-0" aria-hidden="true"></div>
                <div>
                  <h5 class="text-sm font-bold text-slate-800">Fiber Optic Integration</h5>
                  <p class="text-xs text-slate-500 mt-1">Multi-mode and single-mode backbones for campus-wide connectivity.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">

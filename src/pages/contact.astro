---
// ============================================================
// contact.astro — Redesigned Contact page
// Premium Consultation request journey (Tesla / Rivian style)
// ============================================================
import BaseLayout from '@layouts/BaseLayout.astro';
import { company } from '@data/company';
import { pageSEO } from '@data/seo';
import { buildBreadcrumbSchema } from '@lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: company.site.url + '/' },
  { name: 'Contact', url: company.site.url + '/contact/' },
]);

const trustPillars = [
  {
    title: 'Licensed KEB Engineers',
    desc: 'All installations are planned and signed off by certified engineering professionals in compliance with Kerala state laws.'
  },
  {
    title: 'Transparent Project Bidding',
    desc: 'Detailed line-item quotes with clear pricing for materials, panel assembly, wiring layouts, and diagnostic testing.'
  },
  {
    title: 'Premium Brand Alignment',
    desc: 'Authorized deployment of top-tier switchgear and components from Siemens, Schneider, and ABB.'
  }
];

const coverageDistricts = [
  { name: 'Chungathara & Nilambur', note: 'Immediate local dispatch' },
  { name: 'Malappuram District', note: '< 2 Hour response SLA' },
  { name: 'Kozhikode & Wayanad', note: 'Scheduled site visits' },
  { name: 'Palakkad & Thrissur', note: 'Commercial projects only' }
];
---

<BaseLayout seo={pageSEO.contact} jsonLd={[breadcrumb]}>
  
  <!-- HERO SECTION -->
  <section class="relative bg-dark blueprint-bg flex items-center justify-center overflow-hidden" style="padding-top: clamp(8rem, 16vh, 12rem); padding-bottom: clamp(6rem, 10vh, 8rem);" aria-labelledby="contact-hero-title">
    <div class="absolute inset-0 radial-glow pointer-events-none" aria-hidden="none"></div>
    <div class="absolute inset-0 radial-glow-teal pointer-events-none" aria-hidden="none"></div>
    
    <div class="container relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-8 flex justify-center contact-reveal">
        <ol class="flex items-center gap-3 text-xs tracking-widest uppercase text-white/40">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-white/20">/</li>
          <li class="text-white/80" aria-current="page">Consultation</li>
        </ol>
      </nav>
      
      <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-6 contact-reveal delay-100">ENGINEERING ADVISORY</span>
      
      <h1 id="contact-hero-title" class="heading-xl text-white tracking-tighter mb-8 max-w-4xl mx-auto leading-none contact-reveal delay-150">
        Let’s Build <br/>
        <span class="text-white/60">Something Reliable.</span>
      </h1>
      
      <p class="text-white/60 text-base md:text-lg max-w-xl mx-auto leading-relaxed contact-reveal delay-200">
        Book a professional electrical consultation. Discuss system design, load limits, safety regulations, and project scope directly with our engineers.
      </p>
    </div>
  </section>

  <!-- INTERACTIVE CONTACT CHANNELS -->
  <section class="py-12 bg-warm border-b border-black/5" aria-label="Quick contact channels">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Phone Card -->
        <a 
          href={`tel:${company.phone}`} 
          class="flex flex-col justify-between p-6 bg-white border border-slate-900/10 rounded-lg shadow-sm group hover:translate-y-[-2px] transition-transform duration-300 contact-reveal"
          aria-label={`Call us at ${company.phoneDisplay}`}
        >
          <div>
            <span class="text-[9px] uppercase tracking-widest font-bold text-slate-400 block mb-3">PHONE ENQUIRY</span>
            <h3 class="text-slate-900 font-bold text-lg mb-1 group-hover:text-teal-800 transition-colors">{company.phoneDisplay}</h3>
            <p class="text-slate-500 text-xs">Direct line to our dispatch coordinator</p>
          </div>
          <span class="text-xs font-semibold text-teal-800 mt-6 flex items-center gap-1 group-hover:gap-2 transition-all">
            Call Direct <span aria-hidden="true">→</span>
          </span>
        </a>

        <!-- WhatsApp Card -->
        <a 
          href={company.whatsapp} 
          target="_blank" 
          rel="noopener noreferrer"
          class="flex flex-col justify-between p-6 bg-white border border-slate-900/10 rounded-lg shadow-sm group hover:translate-y-[-2px] transition-transform duration-300 contact-reveal delay-100"
          aria-label="Enquire on WhatsApp"
        >
          <div>
            <span class="text-[9px] uppercase tracking-widest font-bold text-teal-700 block mb-3">WHATSAPP CHAT</span>
            <h3 class="text-slate-900 font-bold text-lg mb-1 group-hover:text-teal-800 transition-colors">Instant Response</h3>
            <p class="text-slate-500 text-xs">Send layouts, photos, and project queries</p>
          </div>
          <span class="text-xs font-semibold text-teal-800 mt-6 flex items-center gap-1 group-hover:gap-2 transition-all">
            Start Conversation <span aria-hidden="true">→</span>
          </span>
        </a>

        <!-- Office Hours -->
        <div class="flex flex-col justify-between p-6 bg-white border border-slate-900/10 rounded-lg shadow-sm contact-reveal delay-200">
          <div>
            <span class="text-[9px] uppercase tracking-widest font-bold text-slate-400 block mb-3">BUSINESS HOURS</span>
            <h3 class="text-slate-900 font-bold text-lg mb-1">Mon–Sat: 8AM–7PM</h3>
            <p class="text-slate-500 text-xs">Sun: 9AM–5PM (24/7 emergency standby)</p>
          </div>
          <span class="text-xs font-semibold text-green-700 mt-6 flex items-center gap-2">
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            Active Emergency Support
          </span>
        </div>

      </div>
    </div>
  </section>

  <!-- CONSULTATION FORM & PROTOCOL -->
  <section class="section bg-warm-2 border-b border-black/5" aria-labelledby="form-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        
        <!-- Left Side: Consultation Protocol -->
        <div class="lg:col-span-5 scroll-active-trigger reveal-left">
          <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">THE METHOD</span>
          <h2 id="form-heading" class="heading-lg text-slate-900 mb-6 font-display">
            How We Structure Your Advisory
          </h2>
          <p class="text-slate-600 text-base leading-relaxed mb-8">
            Our consultations are structured around risk-management and budget optimization. We evaluate your load criteria, review component requirements, and draw up installation schedules.
          </p>

          <!-- Steps -->
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <span class="w-8 h-8 rounded-full bg-teal-800/10 text-teal-800 font-display font-bold flex items-center justify-center text-xs flex-shrink-0" aria-hidden="true">01</span>
              <div>
                <h4 class="text-slate-900 font-bold text-sm">System Load Analysis</h4>
                <p class="text-slate-500 text-xs mt-1">We outline the aggregate kilowatt draws, phase balance requirements, and protection thresholds.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="w-8 h-8 rounded-full bg-teal-800/10 text-teal-800 font-display font-bold flex items-center justify-center text-xs flex-shrink-0" aria-hidden="true">02</span>
              <div>
                <h4 class="text-slate-900 font-bold text-sm">Compliance Mapping</h4>
                <p class="text-slate-500 text-xs mt-1">Ensuring that spacing, earthing layout, and breaker sizes match KEB standards.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: The Premium Form -->
        <div class="lg:col-span-7 contact-reveal-scale delay-150">
          <div class="bg-white border border-slate-900/10 rounded-lg p-8 shadow-xl">
            <h3 class="text-slate-900 font-bold text-xl mb-2">Request Consultation</h3>
            <p class="text-slate-500 text-xs mb-8">Enter your project specifications below. Our engineers will prepare diagnostic drafts.</p>
            
            <form id="consultation-form" class="space-y-6" novalidate aria-label="Detailed consultation request form">
              <!-- Honeypot -->
              <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="relative">
                  <label for="form-name" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Full Name *</label>
                  <input 
                    type="text" 
                    id="form-name" 
                    name="name" 
                    required 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors" 
                    placeholder="E.g. Rajesh Kumar"
                    aria-describedby="name-error"
                  />
                  <p id="name-error" class="hidden mt-1 text-[11px] text-red-600" role="alert">Name is required.</p>
                </div>
                
                <!-- Phone -->
                <div class="relative">
                  <label for="form-phone" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Mobile Number *</label>
                  <input 
                    type="tel" 
                    id="form-phone" 
                    name="phone" 
                    required 
                    pattern="[6-9][0-9]{9}"
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors" 
                    placeholder="10-digit number"
                    aria-describedby="phone-error"
                  />
                  <p id="phone-error" class="hidden mt-1 text-[11px] text-red-600" role="alert">Please enter a valid 10-digit number.</p>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- Project Type -->
                <div>
                  <label for="form-service" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Project Category</label>
                  <select 
                    id="form-service" 
                    name="service" 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors"
                  >
                    <option value="">Choose Category...</option>
                    <option value="Home Electrical Solutions">Home Electrical Solutions</option>
                    <option value="Industrial Power Systems">Industrial Power Systems</option>
                    <option value="ATS & AMF Panel Setup">ATS & AMF Panel Setup</option>
                    <option value="Automation & Smart Control">Automation & Smart Control</option>
                    <option value="Structured Cabling & Networks">Structured Cabling & Networks</option>
                    <option value="Surveillance & Security Systems">Surveillance & Security Systems</option>
                    <option value="Repair & Maintenance">Repair & Maintenance</option>
                  </select>
                </div>
                
                <!-- Location -->
                <div>
                  <label for="form-location" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Location in Kerala</label>
                  <input 
                    type="text" 
                    id="form-location" 
                    name="location" 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors" 
                    placeholder="E.g. Chungathara, Nilambur"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- Timeline -->
                <div>
                  <label for="form-timeline" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Timeline</label>
                  <select 
                    id="form-timeline" 
                    name="timeline" 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors"
                  >
                    <option value="">Select Schedule...</option>
                    <option value="Immediate">Immediate / Emergency</option>
                    <option value="1-3 Months">Within 1-3 Months</option>
                    <option value="3+ Months">Planning Stage (&gt; 3 Months)</option>
                  </select>
                </div>
                
                <!-- Preferred contact method -->
                <div>
                  <label for="form-contact-method" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Contact Preference</label>
                  <select 
                    id="form-contact-method" 
                    name="preference" 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors"
                  >
                    <option value="WhatsApp">Send WhatsApp Message</option>
                    <option value="Phone Call">Direct Phone Call</option>
                  </select>
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="form-message" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Message</label>
                <textarea 
                  id="form-message" 
                  name="message" 
                  rows="4" 
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-slate-800 text-sm focus:bg-white focus:border-teal-800 focus:outline-none transition-colors resize-none" 
                  placeholder="Describe your load criteria or installation queries..."
                ></textarea>
              </div>

              <!-- Submit -->
              <button 
                type="submit" 
                id="form-submit-btn" 
                class="w-full py-4 bg-teal-800 text-white font-bold text-sm tracking-widest uppercase hover:bg-teal-900 rounded transition-colors shadow-lg flex items-center justify-center gap-2"
                aria-label="Submit project consultation enquiry via WhatsApp"
              >
                Send Request via WhatsApp
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </button>
              
              <p class="text-[10px] text-center text-slate-400 leading-normal">
                Submitting gathers details and opens WhatsApp Web / Mobile to send directly.
              </p>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- OFFICE SHOWCASE & DIRECTIONS -->
  <section class="section bg-warm border-b border-black/5" aria-labelledby="office-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left details -->
        <div class="lg:col-span-5 contact-reveal">
          <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">HEADQUARTERS</span>
          <h2 id="office-heading" class="heading-lg text-slate-900 mb-6 font-display">
            Chungathara Showcase
          </h2>
          <address class="not-italic text-slate-600 text-sm md:text-base leading-relaxed mb-8">
            <span class="font-bold text-slate-800 text-lg block mb-2">{company.name}</span>
            {company.address.street}<br/>
            {company.address.city}, {company.address.state}<br/>
            PIN – {company.address.zip}
          </address>

          <a 
            href="https://maps.google.com/?q=Chungathara,Nilambur,Kerala" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="btn btn-rect bg-slate-900 text-white hover:bg-slate-800 inline-flex items-center shadow-md"
            aria-label="Open directions on Google Maps"
          >
            Get Direct Directions
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
            </svg>
          </a>
        </div>

        <!-- Right: Map framework -->
        <div class="lg:col-span-7 contact-reveal-scale delay-150">
          <div class="rounded-lg overflow-hidden border border-slate-900/10 shadow-2xl aspect-[16/10] min-h-[300px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31314.58038!2d76.1986!3d11.1187!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba63a5c2b86e4d3%3A0x0!2sChungathara%2C%20Nilambur%2C%20Kerala%20679334!5e0!3m2!1sen!2sin!4v1699999999999!5m2!1sen!2sin"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Google Maps showing Bright Electrical head office"
              aria-label="Google Maps frame showing address in Chungathara, Kerala"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICE AREA SECTION -->
  <section class="section bg-dark blueprint-bg border-b border-white/5" aria-labelledby="coverage-heading">
    <div class="absolute inset-0 radial-glow pointer-events-none" aria-hidden="none"></div>
    <div class="container relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left narrative details -->
        <div class="lg:col-span-6 contact-reveal">
          <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-4">COVERAGE MATRIX</span>
          <h2 id="coverage-heading" class="heading-lg text-white mb-6 font-display">
            Active Kerala Coverage
          </h2>
          <p class="text-white/60 text-base md:text-lg leading-relaxed mb-8">
            From our central engineering workshop in Chungathara, we operate active technical dispatch teams across neighboring zones, ensuring code compliance and fast service SLAs.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {coverageDistricts.map(dist => (
              <div class="border border-white/10 rounded p-4 bg-slate-900/40">
                <span class="text-white font-bold text-sm block mb-1">{dist.name}</span>
                <span class="text-white/40 text-xs font-semibold block">{dist.note}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right illustration list/details -->
        <div class="lg:col-span-6 scroll-active-trigger reveal-right delay-200">
          <div class="bg-slate-900/70 border border-white/10 rounded-lg p-8 shadow-2xl relative overflow-hidden">
            <h4 class="text-xs uppercase tracking-widest font-bold text-teal-400 mb-6 border-b border-white/10 pb-4">Response Threshold SLAs</h4>
            
            <div class="space-y-6">
              <div class="flex items-center justify-between border-b border-white/5 pb-3">
                <span class="text-sm text-white/80 font-bold">Emergency Call-Out</span>
                <span class="text-teal-400 text-sm font-bold">&lt; 2 Hour Response SLA</span>
              </div>
              <div class="flex items-center justify-between border-b border-white/5 pb-3">
                <span class="text-sm text-white/80">Scheduled Audits</span>
                <span class="text-white/60 text-sm">Next-Business-Day Booking</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-white/80">Industrial Installations</span>
                <span class="text-white/60 text-sm">Within 3-5 Business Days</span>
              </div>
            </div>

            <!-- Glow accent light -->
            <div class="absolute -right-16 -bottom-16 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl" aria-hidden="true"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY CONTACT BRIGHT (Trust details) -->
  <section class="section bg-warm border-b border-black/5" aria-labelledby="trust-pillar-title">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16 md:mb-24 contact-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">OUR PRINCIPLES</span>
        <h2 id="trust-pillar-title" class="heading-lg text-slate-900 font-display">Why Contractors Trust Us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
        {trustPillars.map((pillar, i) => (
          <div class="bg-white border border-slate-900/10 rounded-lg p-8 shadow-sm contact-reveal" style={`transition-delay: ${i * 150}ms`}>
            <span class="w-8 h-8 rounded-full bg-teal-800/10 text-teal-800 font-display font-bold flex items-center justify-center text-xs mb-6" aria-hidden="true">0{i + 1}</span>
            <h4 class="text-slate-900 font-bold text-base mb-2">{pillar.title}</h4>
            <p class="text-slate-500 text-xs leading-relaxed">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Welcome Scroll triggers script -->
  <script>
    function initContactScroll() {
      const els = document.querySelectorAll('.contact-reveal, .contact-reveal-scale, .scroll-active-trigger');
      if (els.length === 0) return;

      const hasNativeSDA = CSS.supports('animation-timeline', 'view()');

      if (hasNativeSDA) {
        els.forEach(el => el.classList.add('native-sda'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          } else {
            const rect = entry.boundingClientRect;
            if (rect.top > window.innerHeight) {
              entry.target.classList.remove('revealed');
            }
          }
        });
      }, {
        threshold: 0.05,
        rootMargin: '0px 0px -20px 0px'
      });

      els.forEach(el => observer.observe(el));
    }

    // Bind to page events
    initContactScroll();
    document.addEventListener('astro:page-load', initContactScroll);
  </script>

  <!-- Client-side Form pre-fill & WhatsApp Submit logic -->
  <script>
    function setupFormLogic() {
      // Pre-fill service dropdown from URL queries
      const params = new URLSearchParams(window.location.search);
      const service = params.get('service');
      if (service) {
        const select = document.getElementById('form-service') as HTMLSelectElement;
        if (select) {
          const matchedOpt = Array.from(select.options).find(o => o.value === service);
          if (matchedOpt) select.value = service;
        }
      }

      const form = document.getElementById('consultation-form') as HTMLFormElement;
      if (!form) return;

      const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
      const nameInput = document.getElementById('form-name') as HTMLInputElement;
      const phoneInput = document.getElementById('form-phone') as HTMLInputElement;
      const nameError = document.getElementById('name-error') as HTMLElement;
      const phoneError = document.getElementById('phone-error') as HTMLElement;

      const showError = (errorEl: HTMLElement, inputEl: HTMLInputElement) => {
        errorEl.classList.remove('hidden');
        inputEl.classList.add('border-red-600', 'focus:border-red-600');
        inputEl.setAttribute('aria-invalid', 'true');
      };

      const clearError = (errorEl: HTMLElement, inputEl: HTMLInputElement) => {
        errorEl.classList.add('hidden');
        inputEl.classList.remove('border-red-600', 'focus:border-red-600');
        inputEl.removeAttribute('aria-invalid');
      };

      nameInput.addEventListener('input', () => {
        if (nameInput.value.trim()) clearError(nameError, nameInput);
      });
      phoneInput.addEventListener('input', () => {
        if (/^[6-9]\d{9}$/.test(phoneInput.value.trim())) clearError(phoneError, phoneInput);
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Honeypot spam check
        const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]');
        if (honeypot?.value) return;

        let isValid = true;
        const nameVal = nameInput.value.trim();
        const phoneVal = phoneInput.value.trim();

        if (!nameVal) {
          showError(nameError, nameInput);
          isValid = false;
        } else {
          clearError(nameError, nameInput);
        }

        if (!phoneVal || !/^[6-9]\d{9}$/.test(phoneVal)) {
          showError(phoneError, phoneInput);
          isValid = false;
        } else {
          clearError(phoneError, phoneInput);
        }

        if (!isValid) {
          nameInput.focus();
          return;
        }

        const serviceVal = (document.getElementById('form-service') as HTMLSelectElement).value;
        const locationVal = (document.getElementById('form-location') as HTMLInputElement).value.trim();
        const timelineVal = (document.getElementById('form-timeline') as HTMLSelectElement).value;
        const contactPreference = (document.getElementById('form-contact-method') as HTMLSelectElement).value;
        const messageVal = (document.getElementById('form-message') as HTMLTextAreaElement).value.trim();

        const messageParts = [
          `*Consultation Request — Bright Electrical*`,
          ``,
          `*Name:* ${nameVal}`,
          `*Phone:* ${phoneVal}`,
          serviceVal ? `*Category:* ${serviceVal}` : null,
          locationVal ? `*Location:* ${locationVal}` : null,
          timelineVal ? `*Timeline:* ${timelineVal}` : null,
          contactPreference ? `*Preference:* ${contactPreference}` : null,
          messageVal ? `*Message:* ${messageVal}` : null,
          ``,
          `_Submitted from brightwork.in_`
        ].filter(Boolean).join('\n');

        const waUrl = `https://wa.me/918304910099?text=${encodeURIComponent(messageParts)}`;

        submitBtn.textContent = 'Launching WhatsApp...';
        submitBtn.disabled = true;

        window.open(waUrl, '_blank', 'noopener,noreferrer');

        setTimeout(() => {
          form.reset();
          submitBtn.innerHTML = `
            Send Request via WhatsApp
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          `;
          submitBtn.disabled = false;
        }, 3000);
      });
    }

    // Run on initial load and view transition swap
    setupFormLogic();
    document.addEventListener('astro:page-load', setupFormLogic);
  </script>

</BaseLayout>


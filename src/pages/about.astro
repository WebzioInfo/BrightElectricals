---
// ============================================================
// about.astro — Redesigned About page
// Premium human/craftsmanship editorial aesthetic (Rivian / ABB style)
// ============================================================
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@sections/ContactCTA.astro';
import { company } from '@data/company';
import { pageSEO } from '@data/seo';
import { buildBreadcrumbSchema } from '@lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: company.site.url + '/' },
  { name: 'About Us', url: company.site.url + '/about/' },
]);

const milestones = [
  {
    year: '2014',
    title: 'The Spark',
    desc: 'Founded in Chungathara, Nilambur to bring licensed, safety-first electrical services to residential developments in Malappuram.',
  },
  {
    year: '2018',
    title: 'Industrial Expansion',
    desc: 'Began commissioning heavy power panels, distribution grids, and machinery setups for factories across Northern Kerala.',
  },
  {
    year: '2022',
    title: 'Intelligent Systems',
    desc: 'Integrated smart automation controllers, structured enterprise networking networks, and ATS systems into our capabilities.',
  },
  {
    year: '2026',
    title: 'Statewide Infrastructure',
    desc: 'Surpassed 500 successfully commissioned projects state-wide, trusted by hospitals, apartments, and manufacturing plants.',
  },
];

const pillars = [
  {
    title: 'Absolute Compliance',
    desc: 'Every terminal connection, switchboard setup, and earth loop is designed strictly according to KEB and CEA safety mandates.',
  },
  {
    title: 'Component Integrity',
    desc: 'We never compromise. Every cable and MCC panel component is ISI-marked and sourced directly from premium partners like ABB, Siemens, and Schneider.',
  },
  {
    title: 'Rigorous Testing',
    desc: 'Systems undergo thermal analysis, earth loop impedance checking, and full diagnostic tests prior to grid connection.',
  },
];
---

<BaseLayout seo={pageSEO.about} jsonLd={[breadcrumb]}>
  
  <!-- HERO SECTION -->
  <section class="relative bg-warm border-b border-black/5 overflow-hidden" style="padding-top: clamp(8rem, 16vh, 12rem); padding-bottom: clamp(6rem, 12vh, 10rem);" aria-labelledby="about-hero-title">
    <div class="container relative z-10">
      
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8 about-reveal">
        <ol class="flex items-center gap-3 text-xs tracking-widest uppercase text-slate-500">
          <li><a href="/" class="hover:text-slate-800 transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-300">/</li>
          <li class="text-slate-800 font-semibold" aria-current="page">Our Story</li>
        </ol>
      </nav>
      
      <div class="max-w-4xl border-l-[1px] border-slate-900/10 pl-6 md:pl-10">
        <span class="text-xs uppercase tracking-widest font-bold text-teal-800 block mb-6 about-reveal delay-100">THE BRIGHT ENGINEERING FOUNDATION</span>
        <h1 id="about-hero-title" class="heading-xl text-slate-900 tracking-tighter mb-8 leading-[1.05] about-reveal delay-150">
          Crafting the hidden <br/>
          grids of Kerala.
        </h1>
        <p class="text-slate-600 text-lg md:text-xl max-w-2xl leading-relaxed font-body about-reveal delay-200" style="font-weight: 400;">
          For over twelve years, our team has built, automated, and supported robust electrical infrastructure — merging engineering safety with a master craftsman’s detail.
        </p>
      </div>

    </div>
  </section>

  <!-- WHO WE ARE SECTION -->
  <section class="section bg-warm-2 border-b border-black/5" aria-labelledby="who-we-are-title">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left narrative column -->
        <div class="lg:col-span-6 about-reveal-left">
          <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">WHO WE ARE</span>
          <h2 id="who-we-are-title" class="heading-lg text-slate-900 mb-6 font-display">
            A Legacy Built on Professional Trust
          </h2>
          <div class="prose-custom space-y-6 text-slate-600">
            <p>
              Bright Electrical and Engineering Works was established in Chungathara, Nilambur, with a simple, uncompromising objective: to provide safe, highly-engineered electrical systems that residential and industrial sectors could depend upon.
            </p>
            <p>
              From custom villas to large-scale production facilities, our work is defined by precision. Every distribution box is neatly dressed, every load is precisely balanced, and every installation undergoes exhaustive safety checking.
            </p>
            <p>
              Under the leadership of KEB-certified engineers, our technicians continue to deliver clean, code-compliant, and future-ready installations across the length and breadth of Kerala.
            </p>
          </div>
        </div>

        <!-- Right asymmetrical overlapping composition -->
        <div class="lg:col-span-6 relative flex justify-center items-center py-8 about-reveal-right delay-200">
          <!-- Main Image -->
          <div class="relative w-full max-w-[480px] aspect-[4/3] rounded-lg overflow-hidden border border-slate-900/10 shadow-xl z-10 hover:scale-[1.01] transition-transform duration-500">
            <img 
              src="/images/about-work.webp" 
              alt="Bright Electrical engineering team during installation" 
              class="w-full h-full object-cover filter brightness-[0.94] contrast-[1.03]"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
          </div>
          
          <!-- Decorative Floating Card -->
          <div class="absolute -bottom-4 -left-4 md:-left-8 bg-slate-900 text-white p-6 rounded-lg border border-slate-800 shadow-2xl z-20 max-w-[200px]" aria-label="Company scale">
            <p class="font-display font-900 text-4xl text-teal-400" style="letter-spacing: -0.04em;">500<span class="text-white">+</span></p>
            <p class="text-[10px] tracking-wider uppercase text-white/60 font-semibold mt-1">Infrastructure deployments across Kerala</p>
          </div>
          
          <!-- Outer border decorative outline -->
          <div class="absolute -inset-2 border border-dashed border-slate-900/10 rounded-lg -z-0 pointer-events-none" aria-hidden="true"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- OUR PHILOSOPHY (Pull Quote Section) -->
  <section class="section bg-slate-900 border-b border-white/5 relative overflow-hidden" aria-labelledby="philosophy-quote">
    <!-- Gradient Lighting Glow -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 60%);" aria-hidden="true"></div>
    
    <div class="container relative z-10 text-center py-12 md:py-20">
      <div class="max-w-4xl mx-auto about-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-8">OUR ENGINEERING PHILOSOPHY</span>
        
        <blockquote id="philosophy-quote" class="font-display text-2xl md:text-4xl text-white italic leading-relaxed tracking-tight mb-8">
          "We believe in the beauty of structured, code-compliant systems. A neatly labeled distribution box, an optimal load pathway, a perfectly stable backup system — this is how we craft safety."
        </blockquote>
        
        <cite class="text-xs uppercase tracking-widest font-semibold text-white/50 not-italic block">— BRIGHT ELECTRICAL CORE PRINCIPLE</cite>
      </div>
    </div>
  </section>

  <!-- OUR JOURNEY (Timeline Section) -->
  <section class="section bg-dark blueprint-bg border-b border-white/5 relative overflow-hidden" aria-labelledby="journey-title">
    <!-- Grid overlay texture -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 50% 50%, rgba(13, 79, 92, 0.15) 0%, transparent 70%);" aria-hidden="true"></div>
    
    <div class="container relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-16 md:mb-24 about-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-4">OUR CHRONOLOGY</span>
        <h2 id="journey-title" class="heading-lg text-white font-display">Our Decadelong Development</h2>
      </div>

      <!-- Asymmetrical Journey Timeline -->
      <div class="relative border-l border-white/10 ml-4 md:ml-12 space-y-16">
        {milestones.map((item, index) => (
          <div class="relative pl-8 md:pl-16 about-reveal" style={`transition-delay: ${index * 150}ms`}>
            <!-- Dot -->
            <div class="absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full bg-teal-400 shadow-[0_0_8px_rgba(45,212,191,0.8)] border border-slate-900" aria-hidden="true"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
              <!-- Left: Year -->
              <div class="md:col-span-2">
                <span class="font-display font-900 text-3xl md:text-4xl text-teal-400 tracking-tight block leading-none">{item.year}</span>
              </div>
              <!-- Right: Content -->
              <div class="md:col-span-10">
                <h4 class="text-white font-bold text-lg mb-2">{item.title}</h4>
                <p class="text-white/60 text-sm md:text-base leading-relaxed max-w-3xl">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ENGINEERING STANDARDS (Wide photo overlay section) -->
  <section class="relative bg-slate-950 overflow-hidden border-b border-white/5 py-32 md:py-48" aria-labelledby="standards-title">
    <!-- Full-width cinematic background photo -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero-cinematic.webp" 
        alt="High-voltage power substation infrastructure" 
        class="w-full h-full object-cover filter brightness-[0.3] contrast-[1.05] about-parallax-img"
        loading="lazy"
        decoding="async"
      />
      <!-- Soft blue lighting shader -->
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-transparent pointer-events-none" aria-hidden="true"></div>
    </div>

    <div class="container relative z-10">
      <div class="max-w-3xl border-l-[1px] border-white/20 pl-6 md:pl-10 about-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-6">REGULATORY & SAFETY DIRECTIVES</span>
        <h2 id="standards-title" class="heading-lg text-white mb-6 font-display">
          Built to Legrand, Siemens, & CEA Standards
        </h2>
        <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-2xl">
          We maintain regulatory clearances and follow Kerala Electricity Board (KEB) guidelines. Our design methodologies emphasize clean cabling runs, clear thermal profiles, and structured switchgear setups that prevent grid failures.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK (Step-by-step layout) -->
  <section class="section bg-warm border-b border-black/5" aria-labelledby="how-we-work-title">
    <div class="container">
      
      <div class="text-center max-w-2xl mx-auto mb-16 md:mb-24 about-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">OUR SERVICE PROTOCOL</span>
        <h2 id="how-we-work-title" class="heading-lg text-slate-900 font-display">Methodical Execution Steps</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
        {pillars.map((pillar, i) => (
          <div class="bg-white border border-slate-900/10 rounded-lg p-8 shadow-sm flex flex-col justify-between about-reveal" style={`transition-delay: ${i * 150}ms`}>
            <div>
              <span class="font-display font-900 text-3xl text-teal-800/20 block mb-6">0{i + 1} //</span>
              <h4 class="text-slate-900 font-bold text-lg mb-3">{pillar.title}</h4>
              <p class="text-slate-600 text-sm leading-relaxed">{pillar.desc}</p>
            </div>
            <div class="w-8 h-[1px] bg-slate-900/10 mt-8" aria-hidden="true"></div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- WHY CLIENTS TRUST US -->
  <section class="section bg-warm-2 border-b border-black/5" aria-labelledby="trust-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Left: Asymmetrical Grid of Trust details -->
        <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6 items-stretch order-last lg:order-first">
          
          <div class="bg-white border border-slate-900/10 rounded-lg p-6 shadow-sm about-reveal">
            <h4 class="text-slate-900 font-bold text-base mb-2">Zero-Downtime Mentality</h4>
            <p class="text-slate-500 text-xs leading-relaxed">We design redundancy directly into commercial systems, implementing automated AMF switchovers that protect your operations.</p>
          </div>
          
          <div class="bg-white border border-slate-900/10 rounded-lg p-6 shadow-sm about-reveal delay-100">
            <h4 class="text-slate-900 font-bold text-base mb-2">Transparent Quotations</h4>
            <p class="text-slate-500 text-xs leading-relaxed">No estimated padding. Every invoice details components, labor hours, and cable lengths for full price clarity.</p>
          </div>
          
          <div class="bg-white border border-slate-900/10 rounded-lg p-6 shadow-sm about-reveal delay-200">
            <h4 class="text-slate-900 font-bold text-base mb-2">KEB-Certified Technicians</h4>
            <p class="text-slate-500 text-xs leading-relaxed">Our execution staff are fully certified, ensuring that installations comply with state electricity rules.</p>
          </div>
          
          <div class="bg-white border border-slate-900/10 rounded-lg p-6 shadow-sm about-reveal delay-300">
            <h4 class="text-slate-900 font-bold text-base mb-2">Rapid AMC Support</h4>
            <p class="text-slate-500 text-xs leading-relaxed">We guarantee scheduled visits and provide immediate 24/7 priority dispatch response times for critical contracts.</p>
          </div>

        </div>

        <!-- Right: Editorial Header -->
        <div class="lg:col-span-5 about-reveal-right">
          <span class="text-xs uppercase tracking-widest font-bold text-slate-500 block mb-4">THE TRUST GRID</span>
          <h2 id="trust-heading" class="heading-lg text-slate-900 mb-6 font-display">
            Why Kerala’s Enterprises Rely On Us
          </h2>
          <p class="text-slate-600 text-base leading-relaxed mb-8">
            Electrical engineering is not just about running cables; it is about risk mitigation. We build protective layers into every deployment so that your operations run uninterrupted.
          </p>
          <a 
            href="/contact/" 
            class="text-sm text-teal-800 hover:text-teal-900 font-bold flex items-center gap-1 group"
            aria-label="View contact information"
          >
            Review Our Certifications
            <span class="group-hover:translate-x-1 transition-transform inline-block" aria-hidden="true">→</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- NUMBERS THAT MATTER -->
  <section class="section bg-slate-950 border-b border-white/5 relative overflow-hidden" aria-labelledby="metrics-title">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.04) 0%, transparent 60%);" aria-hidden="true"></div>
    <div class="container relative z-10">
      
      <div class="border-b border-white/10 pb-10 mb-16 text-center max-w-xl mx-auto about-reveal">
        <span class="text-xs uppercase tracking-widest font-bold text-teal-400 block mb-3">KEY PERFORMANCE METRICS</span>
        <h2 id="metrics-title" class="text-white text-2xl font-bold font-display">Engineering Deliverables</h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 text-center">
        
        <div class="about-reveal">
          <p class="font-display font-900 text-5xl lg:text-6xl text-white tracking-tight leading-none mb-2">500<span class="text-teal-400">+</span></p>
          <p class="text-white/40 text-xs uppercase tracking-widest font-semibold">Projects Completed</p>
        </div>
        
        <div class="about-reveal delay-100">
          <p class="font-display font-900 text-5xl lg:text-6xl text-white tracking-tight leading-none mb-2">12<span class="text-teal-400">+</span></p>
          <p class="text-white/40 text-xs uppercase tracking-widest font-semibold">Years Experience</p>
        </div>
        
        <div class="about-reveal delay-200">
          <p class="font-display font-900 text-5xl lg:text-6xl text-white tracking-tight leading-none mb-2">100<span class="text-teal-400">%</span></p>
          <p class="text-white/40 text-xs uppercase tracking-widest font-semibold">KEB Compliance</p>
        </div>
        
        <div class="about-reveal delay-300">
          <p class="font-display font-900 text-5xl lg:text-6xl text-white tracking-tight leading-none mb-2">2<span class="text-teal-400">Hr</span></p>
          <p class="text-white/40 text-xs uppercase tracking-widest font-semibold">Emergency Dispatch SLA</p>
        </div>

      </div>

    </div>
  </section>

  <!-- Final CTA section -->
  <ContactCTA />

  <!-- Custom Organic Scroll reveal triggers -->
  <script>
    function initAboutScroll() {
      const els = document.querySelectorAll('.about-reveal, .about-reveal-left, .about-reveal-right, .about-parallax-img');
      if (els.length === 0) return;

      const hasNativeSDA = CSS.supports('animation-timeline', 'view()');

      if (hasNativeSDA) {
        els.forEach(el => el.classList.add('native-sda'));
        return;
      }

      // Fallback: Custom IntersectionObserver that removes class when element leaves bottom (reverses when scrolling back up)
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            } else {
              const rect = entry.boundingClientRect;
              if (rect.top > window.innerHeight) {
                entry.target.classList.remove('revealed');
              }
            }
          });
        },
        { threshold: 0.05, rootMargin: '0px 0px -20px 0px' }
      );

      els.forEach((el) => observer.observe(el));
    }

    // Bind to page load and view transitions
    initAboutScroll();
    document.addEventListener('astro:page-load', initAboutScroll);
  </script>

</BaseLayout>

<style>
  /* ─── Premium Redesign Scoped Styles ─── */
  
  /* Blueprint Grid background texture for About journey chapter */
  .blueprint-bg {
    background-color: #0C1A2A;
    background-image: 
      linear-gradient(rgba(59, 130, 246, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    background-position: center;
  }

  /* ─── Native Scroll-Driven Animations Timeline ─── */
  @keyframes about-reveal-native {
    0% {
      opacity: 0;
      transform: translateY(40px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes about-reveal-left-native {
    0% {
      opacity: 0;
      transform: translateX(-40px) rotate(-0.5deg);
    }
    100% {
      opacity: 1;
      transform: translateX(0) rotate(0deg);
    }
  }
  @keyframes about-reveal-right-native {
    0% {
      opacity: 0;
      transform: translateX(40px) rotate(0.5deg);
    }
    100% {
      opacity: 1;
      transform: translateX(0) rotate(0deg);
    }
  }
  @keyframes about-parallax-native {
    0% {
      transform: translateY(30px);
    }
    100% {
      transform: translateY(0);
    }
  }

  /* Apply scroll-driven animations natively if supported */
  .about-reveal.native-sda {
    animation: about-reveal-native linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 25%;
  }
  .about-reveal-left.native-sda {
    animation: about-reveal-left-native linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 25%;
  }
  .about-reveal-right.native-sda {
    animation: about-reveal-right-native linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 25%;
  }
  .about-parallax-img.native-sda {
    animation: about-parallax-native linear both;
    animation-timeline: view();
    animation-range: entry 0% cover 50%;
  }

  /* ─── Fallback triggers toggled by IntersectionObserver ─── */
  .about-reveal:not(.native-sda),
  .about-reveal-left:not(.native-sda),
  .about-reveal-right:not(.native-sda),
  .about-parallax-img:not(.native-sda) {
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.19, 1, 0.22, 1),
                transform 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform, opacity;
  }
  .about-reveal:not(.native-sda) {
    transform: translateY(40px) scale(0.98);
  }
  .about-reveal-left:not(.native-sda) {
    transform: translateX(-40px) rotate(-0.5deg);
  }
  .about-reveal-right:not(.native-sda) {
    transform: translateX(40px) rotate(0.5deg);
  }
  .about-parallax-img:not(.native-sda) {
    transform: translateY(30px);
  }

  /* Active states for JS fallback */
  .about-reveal.revealed:not(.native-sda),
  .about-reveal-left.revealed:not(.native-sda),
  .about-reveal-right.revealed:not(.native-sda),
  .about-parallax-img.revealed:not(.native-sda) {
    opacity: 1;
    transform: translateY(0) translateX(0) scale(1) rotate(0deg);
  }
</style>

---
// ============================================================
// about.astro — About page
// ============================================================
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@sections/ContactCTA.astro';
import { company } from '@data/company';
import { pageSEO } from '@data/seo';
import { buildBreadcrumbSchema } from '@lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: company.site.url + '/' },
  { name: 'About Us', url: company.site.url + '/about/' },
]);

const values = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Safety First',
    desc: 'Every installation follows Kerala Electricity Board standards. We never cut corners on safety — not for speed, not for cost.',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Quality Workmanship',
    desc: 'We use only ISI-marked, certified materials. Our team takes pride in clean, precise, lasting installations.',
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
    title: 'Client Focused',
    desc: 'We listen before we act. Every project begins with understanding your specific needs, budget, and timeline.',
  },
  {
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Transparent Pricing',
    desc: 'Detailed quotations, no hidden charges, no surprises. You always know exactly what you\'re paying for.',
  },
];
---

<BaseLayout seo={pageSEO.about} jsonLd={[breadcrumb]}>
  <!-- Page Hero -->
  <section class="relative overflow-hidden bg-dark" style="padding-top: clamp(8rem, 16vh, 12rem); padding-bottom: clamp(4rem, 8vh, 6rem);" aria-labelledby="about-hero-heading">
    <div class="absolute inset-0 texture-blueprint" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 60% at 80% 20%, rgba(6,182,212,0.08) 0%, transparent 70%);" aria-hidden="true"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm" style="color: #64748B;">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li style="color: #F1F5F9;" aria-current="page">About Us</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <p class="section-label section-label-light mb-4">About Us</p>
        <h1
          id="about-hero-heading"
          class="heading-lg text-white mb-5"
        >
          Kerala's Trusted Electrical Engineering Partner
        </h1>
        <p style="font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); line-height: 1.8; color: #94A3B8; max-width: 600px;">
          Founded with a commitment to safety, quality, and client satisfaction, Bright Electrical and Engineering Works has grown into one of Kerala's most trusted electrical contractors — serving residential, commercial, and industrial clients across the state.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section bg-warm" aria-labelledby="story-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="section-label mb-4">Our Story</p>
          <h2
            id="story-heading"
            class="heading-md mb-5"
          >
            Built on a Foundation of Expertise and Trust
          </h2>
          <div class="prose-custom space-y-4">
            <p>
              Bright Electrical and Engineering Works was established with a clear vision: to provide safe, high-quality electrical services that Kerala's homes, businesses, and industries could rely on. Based in Chungathara, Nilambur, in the heart of Malappuram district, we serve clients across the length and breadth of Kerala.
            </p>
            <p>
              Over the years, we have completed over 500 projects ranging from simple domestic wiring to complex industrial power installations. Every project, regardless of size, receives the same level of care, attention, and professionalism that defines our work.
            </p>
            <p>
              Our team of licensed, KEB-certified electricians stays updated with the latest safety standards, technologies, and best practices in electrical engineering — ensuring every installation is built to last and fully compliant.
            </p>
          </div>
        </div>

        <div class="relative reveal delay-200">
          <div class="rounded-2xl overflow-hidden" style="aspect-ratio: 16/10; box-shadow: var(--shadow-xl);">
            <img
              src="/images/about-work.jpg"
              alt="Bright Electrical team working on a professional installation"
              width="700"
              height="394"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-5 -left-5 rounded-xl p-5" style="background: var(--brand-primary); box-shadow: var(--shadow-lg);" aria-label="12+ years of experience">
            <p class="font-display font-900 text-3xl text-white" style="letter-spacing: -0.04em;">12<span style="color: var(--brand-accent-lt);">+</span></p>
            <p style="font-size: 0.6875rem; color: rgba(255,255,255,0.6); margin-top: 2px; font-weight: 500;">Years Experience</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-warm-2 texture-grid" aria-labelledby="values-heading">
    <div class="container relative z-10">
      <div class="text-center max-w-xl mx-auto" style="margin-bottom: clamp(2.5rem, 5vw, 4rem);">
        <p class="section-label mb-4 reveal">Our Values</p>
        <h2
          id="values-heading"
          class="heading-md reveal delay-100"
        >
          What Drives Everything We Do
        </h2>
      </div>
      <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" style="gap: clamp(0.75rem, 1.5vw, 1.25rem);">
        {values.map((val, i) => (
          <div class="card-light p-6 reveal" style={`transition-delay: ${i * 100}ms`}>
            <dt>
              <div class="icon-box icon-box-light mb-4" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={val.icon} />
                </svg>
              </div>
              <span class="font-display font-700 text-base block mb-2" style="color: var(--text-primary);">{val.title}</span>
            </dt>
            <dd style="font-size: 0.8125rem; line-height: 1.7; color: var(--text-muted);">{val.desc}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="section bg-warm" aria-labelledby="contact-info-heading">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2
          id="contact-info-heading"
          class="heading-md mb-8 reveal"
        >
          Get In Touch
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-8 text-sm">
          <div class="flex flex-col items-center gap-2 reveal">
            <div class="icon-box icon-box-light" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.1a16 16 0 006 6l1.41-1.41a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15z"/>
              </svg>
            </div>
            <p class="font-semibold" style="color: var(--text-primary);">Phone</p>
            <a href={`tel:${company.phone}`} style="color: var(--brand-primary);" class="hover:text-brand-accent transition-colors">{company.phoneDisplay}</a>
          </div>
          <div class="flex flex-col items-center gap-2 reveal delay-100">
            <div class="icon-box icon-box-light" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <p class="font-semibold" style="color: var(--text-primary);">Address</p>
            <address class="not-italic text-center" style="color: var(--text-muted);">{company.address.full}</address>
          </div>
          <div class="flex flex-col items-center gap-2 reveal delay-200">
            <div class="icon-box icon-box-light" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
              </svg>
            </div>
            <p class="font-semibold" style="color: var(--text-primary);">Hours</p>
            <p style="color: var(--text-muted);" class="text-center">Mon–Sat: 8AM–7PM<br />Sun: 9AM–5PM<br /><span class="text-green-600 font-medium">24/7 Emergency</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
